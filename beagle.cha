! TwoDTransformation methodsFor: 'computing' !
inverseRotationMatrix 

	^Matrix fromArray:
			(Array
				with: (Array with: self rotation cos with: self rotation sin with: 0.0)
				with: (Array with: self rotation sin negated with: self rotation cos with: 0.0)
				with: (Array with: 0.0 with: 0.0 with: 1.0)) ! !
