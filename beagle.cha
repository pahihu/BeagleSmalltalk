doit ^[StringArtWindow methodsFor: 'building'] value ! !
! StringArtWindow methodsFor: 'building' !
buildOn: aWindowBuilder

	aWindowBuilder
		verticalLayout: '35px 1fr 200px' id: 'StringArtDiv';
			horizontalLayout: '5sp 100px 100px 100px 100px 100px 100px 100px 1fr' id: 'toolBar';
				pushButton: 'clearStrings';
					label: 'Clear Strings';
					action: [self clearScreen. self board clearStrings. self update];
				end;
				pushButton: 'clearPins';
					label: 'Clear Pins';
					action: [self clearScreen. self board clearPins. self update];
				end;
				pushButton: 'draw';
					label: 'Draw';
					action: [self doAndDrawBoard];
				end;
				pushButton: 'hideLabels';
					label: 'Hide Labels';
					action: [self clearScreen. self board hideLabels. self update];
				end;
				pushButton: 'showLabels';
					label: 'Show Labels';
					action: [self clearScreen. self board showLabels. self update];
				end;
				pushButton: 'inspect';
					label: 'Inspect';
					action: [self board inspect. self update];
				end;
				pushButton: 'browse';
					label: 'Browse';
					action: [CodeBrowser openOnClass: self board class];
				end;
				divId: 'toolbarWhiteSpace';
				end;
			end;
		horizontalLayout: '1fr 1fr' id: 'canvasLayout';
			richTextWidget: #workspace;
				menu: self codeMenu;
				subject: self;
			end;
			canvasWidget: #canvas;
			end;
		end;
		richTextWidget: #boardView;
			subject: self board;
		end;
	end   ! !
