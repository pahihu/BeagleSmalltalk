	| browser |
	browser := self new
		browserPlugin: KitBrowserPlugin new;
		open;
		yourself ! !
! Doit class methodsFor: 'doit' !
doit ^[CodeBrowser class methodsFor: 'opening'] value ! !
! CodeBrowser class methodsFor: 'opening' !
openKitBrowserAt: aPoint

	| browser |
	browser := self new
		origin: aPoint;
		browserPlugin: KitBrowserPlugin new;
		open;
		yourself
 ! !
! Doit class methodsFor: 'doit' !
doit ^[CodeBrowser class methodsFor: 'opening'] value ! !
! CodeBrowser class methodsFor: 'opening' !
openMethodsBrowserOn: aCollection at: aPoint title: aString

	| browser |

	browser := self new
		origin: aPoint;
		browserPlugin: MethodBrowserPlugin new;
		methods: (aCollection sortedBy: [:a :b | a first name, (a at: 3) < (b first name , (b at: 3))]);
		title: aString;
		open;
		yourself
 ! !
! Doit class methodsFor: 'doit' !
doit ^[CodeBrowser class methodsFor: 'opening'] value ! !
! CodeBrowser class methodsFor: 'opening' !
openOnClass: aClass

	| browser |
	browser := self new
		browserPlugin: KitBrowserPlugin new;
		open;
		computeKitList;
		selectedKit: aClass kit;
		computeClassList;
		selectedClass: aClass;
		instanceOrClass: #instance;
		computeProtocolsList;
		updateBrowser ! !
