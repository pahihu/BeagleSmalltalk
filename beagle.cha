browseImplementers
	| selector |

	RequestBox request: 'Method name?' initialAnswer: '' answerBlock: [:methodName |
		methodName notNil ifTrue: [
			CodeBrowser openMethodsBrowserOn: (BeagleSystem implementersOf: methodName asSymbol) at: 100 @ 100 title: 'Implementers of ', methodName] ] ! !
