			attributeAt: 'id' put: (self idFor: 'enableDisable');
			attributeAt: 'style' put: self enableDisableStyle;
			attributeAt: 'onmousedown' put: self enableClickCallbackString.

		self titleBarDivOn: builder.
		self renderBodyOn: builder]
  ! !
