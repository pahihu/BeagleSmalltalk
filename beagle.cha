! WebSocket methodsFor: 'accessing' !
send: aString

	| payload |

	payload := aString asByteArray.
	
	stream
		reset;
		nextPut: 16r81;   "Final frame - text"
		nextPutAll: (self lengthFor: aString);
		nextPutAll: payload;
		commit ! !
