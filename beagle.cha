	"pragmaLiteral ::= INTEGER | FLOAT | CHARACTER | ARRAY | BYTEARRAY | STRING | SYMBOL"

	self oneOf: [
		self token: IntegerToken;
			token: FloatToken;
			token: CharacterToken;
