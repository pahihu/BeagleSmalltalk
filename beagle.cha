doit ^[CodeBrowser methodsFor: 'method menus'] value ! !
! CodeBrowser methodsFor: 'method menus' !
methodMessagesWith: aDictionary

	| selectors |
	self selectedMethod isNil ifTrue: [^self].

	selectors := (self selectedMethod first compiledMethodAt: (self selectedMethod at: 3)) allMessages.
	ListChoiceBox new
		message: 'Selector?';
		choices: selectors;
		values: selectors;
		answerBlock: [:selector |
			self class
				openMethodsBrowserOn: (BeagleSystem implementersOf: selector) at: (aDictionary at: 'pageX') @ (aDictionary at: 'pageY') title: 'Implementers of ', selector];
		open

	  ! !
