doit ^[CodeBrowser methodsFor: 'utility'] value ! !
! CodeBrowser methodsFor: 'utility' !
selectedClassOrMetaclass

	^self isClassMethods
		ifTrue: [self selectedClass class]
		ifFalse: [self selectedClass] ! !
