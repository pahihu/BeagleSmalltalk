printHexOn: aStream

	self positive
		ifTrue: [aStream nextPutAll: '+']
		ifFalse: [aStream nextPutAll: '-'].

	aStream nextPut: $[.
	1 to: self bytes size do: [:index |
		aStream nextPutAll: (self bytes at: index) hex.
		aStream space].
	aStream nextPut: $] ! !
