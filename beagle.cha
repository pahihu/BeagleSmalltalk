! WriteStream methodsFor: 'writing' !
grow

	| newCollection |

	newCollection := collection class new: ((collection size * 2) max: 10).
	1 to: collection size do: [:index |
		newCollection at: index put: (collection at: index)].

	collection := newCollection ! !
