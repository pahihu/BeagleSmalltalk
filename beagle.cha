	self extent isNil ifTrue: [^'display: grid; grid-template-columns: 1fr 8px; background-color: transparent; width: 100%; height: 8px; position: absolute;'].

	^'display: grid; grid-template-columns: 1fr 8px; background-color: transparent; width: 100%; height: 8px; position: absolute; left: 0; top: ', (self bounds corner y) printString, 'px;' ! !
