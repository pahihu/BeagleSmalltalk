! WebUI methodsFor: 'resizing' !
resizeBottomLeftWindow: aDictionary

	| offset oldDragPoint right newExtent left |

	dragPoint isNil ifTrue: [^self].

	right := self origin x + self extent x.
	newExtent := (self minimumSize x max: right - (aDictionary at: 'pageX')) @ ((aDictionary at: 'pageY') - self origin y).
	left := right - newExtent x.

	self extent: newExtent.
	self origin:  left @ self origin y.

	self resizeFrame.
	self windowResized    ! !
