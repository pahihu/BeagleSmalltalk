doit ^[CodeBrowser methodsFor: 'updating'] value ! !
! CodeBrowser methodsFor: 'updating' !
updateCodePane

	self codeBoxWidget text: self code.

	self highlightFor: self codeBoxWidget.

	self codeBoxWidget updateText ! !
