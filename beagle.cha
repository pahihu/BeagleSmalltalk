! JSONLexicalAnalyzer methodsFor: 'reading' !
readInteger

	| number sign |
	number := 0.
	sign := 1.
	self next = $-
		ifTrue: 
			[sign := -1.
			self advance].
	[self next isDigit] whileTrue: 
			[number := number * 10 + self next digitValue.
			self advance].
	^sign * number ! !
