subStringFrom: i to: j

	| subString |
	i < 0 ifTrue: [^self].
	j > self size ifTrue: [^self].
	subString := self class new: (j - i) + 1.
	i to: j do: [:index |
		subString at: (index - i + 1) put: (self at: index).
