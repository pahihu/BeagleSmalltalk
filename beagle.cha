		nextPutAll: 'Args: ';
		print: self numberOfArguments;
		nextPutAll: ' Temporaries: ';
		print: self numberOfTemporaries;
		nextPutAll: ' Copied: ';
		print: self numberOfCopiedVariables;
		cr ! !
