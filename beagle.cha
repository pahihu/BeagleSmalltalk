doit ^[JSONParser methodsFor: 'parsing'] value ! !
! JSONParser methodsFor: 'parsing' !
parsePrimitiveObject
	"primitiveObject ::= special | integer | float | string"

	self oneOf: 
			[self
				token: SpecialWordToken;
				token: IntegerToken;
				token: FloatToken;
				token: StringToken;
				produce: [:rule | rule result token value]] ! !
