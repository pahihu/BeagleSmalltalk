	| stream |
	stream := WriteStream on: (String new: 100).
	stream nextPutAll: '5sp 1fr '.
	self choices size timesRepeat: [stream nextPutAll: '80px '].
	stream nextPutAll: '1fr'.
	^stream contents
  ! !
