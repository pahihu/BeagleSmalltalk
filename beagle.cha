! Doit class methodsFor: 'doit' !
doit ^[RichTextEditorComponent methodsFor: 'evaluating'] value ! !
! RichTextEditorComponent methodsFor: 'evaluating' !
evaluate: aString from: start to: end onError: aBlock

	^[SmalltalkParser evaluate: aString for: self subject]
		on: CompileError
		do: [:ex |
 			| convertedString endOffset code |
			convertedString := self text lfToCR.

			"The 7 skips past the doit ^[ added in by the evaluate"
			endOffset := start + (ex endSourceOffset - 7 + 1 min: convertedString size).

			code :=
				(convertedString copyFrom: 1 to: endOffset),
				' ' , ex message asString, ' ',
				(convertedString copyFrom: endOffset + 1 to: convertedString size).

			self
				text: code;
				updateText;
				setSelectionFrom: endOffset to: endOffset + 2 + ex message asString size.
 			aBlock value]  ! !
! Doit class methodsFor: 'doit' !
doit ^[RichTextEditorComponent methodsFor: 'evaluating'] value ! !
! RichTextEditorComponent methodsFor: 'evaluating' !
evaluateAll

	^self evaluateFor: self subject 

 ! !
