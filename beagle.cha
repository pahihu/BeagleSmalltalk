doit ^[TwoDTransformation methodsFor: 'computing'] value ! !
! TwoDTransformation methodsFor: 'computing' !
inverseScaleMatrix

	self scale isNumber ifTrue: [^self inverseScaleMatrixFromScalar].
	self scale class = Point ifTrue: [^self inverseScaleMatrixFromPoint].
	self scale class = Array ifTrue: [^self inverseScaleMatrixFromArray].

	self error: 'Scale is the wrong type'

 ! !
