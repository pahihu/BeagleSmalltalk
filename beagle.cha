! CodeBrowser methodsFor: 'kit menus' !
unloadKitWith: aDictionary

	| reason |

	self selectedKit isNil ifTrue: [^self].

	reason := self selectedKit cantUnloadReason.
	reason notNil ifTrue: [^self message: reason].

	self selectedKit unload.
	self
		clearClasses;
		computeKitList;
		updateBrowser ! !
