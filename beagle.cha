startTag: aString

	| tag |

	tag := HTMLTag name: aString.

	htmlNode isNil ifTrue: [htmlNode := tag].

	self currentNode ifNotNil: [:node | node addTag: tag].

	self nodeStack add: tag.
	self currentNode: tag. ! !
