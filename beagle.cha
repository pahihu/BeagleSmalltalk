writeMethodOffsets: anArray

	anArray isNil ifTrue: [^self].

	self sourceOffsets
		at: 1 put: 2;
		at: 2 put: (anArray at: 1);
		at: 3 put: (anArray at: 2).

	self literals do: [:eachLiteral |
		eachLiteral isCompiledBlock ifTrue: [
