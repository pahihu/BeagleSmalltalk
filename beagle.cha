! CodeBrowser methodsFor: 'method menus' !
methodMessagesMenuItem

	^PopupMenuItem new
		id: #methodMessages;
		name: 'Messages';
		addRequestedValue: 'pageX';
		addRequestedValue: 'pageY';
		enabledBlock: [self selectedMethod notNil];
		action: [:args | self methodMessagesWith: args];
		yourself ! !
