! WebUI methodsFor: 'opening' !
enableClickCallbackString

	| stream |

	stream := WriteStream on: (String new: 40).
	stream
		nextPutAll: 'requestedFieldsCallback(''$', self appName, ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''bringToTop:'', [''pageX'', ''pageY''], event);'.

	^stream contents  ! !
