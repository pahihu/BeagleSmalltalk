! Matrix methodsFor: 'printing' !
javascriptString

	| stream |
	stream := WriteStream on: (String new: 1000).

	stream nextPut: $[.

	self elements do: [:each |
		stream print: each;
			nextPutAll: ', '].

	stream nextPut: $].
	^stream contents
  ! !
