! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
circularRainbow

	| color |

	self clearStrings.
	self circleWithCenter: 80.

	color := Color red: 255 green: 0 blue: 0 alpha: 255.

	1 to: 79 do: [:i |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 81;
			moveToPin: i ;
			moveToPin: i + 1;
			endPolygon.
		color := color hue: color hue + (360.0 / 80.0)].

		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 81;
			moveToPin: 80;
			moveToPin: 1;
			endPolygon.
 ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
hexagonArches

	| color |

	self hexagonWithSides: 20.

	color := Color red: 255 green: 0 blue: 0.

	1 to: 20 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	21 to: 40 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	41 to: 60 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	61 to: 80 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	81 to: 100 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	101 to: 120 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)]
 ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
hexagonDoubleArches

	| color |

	self hexagonWithSides: 20.

	color := Color red: 255 green: 0 blue: 0.

	1 to: 20 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 40.
		color := color hue: color hue + (360.0 / 120.0)].

	21 to: 40 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 40.
		color := color hue: color hue + (360.0 / 120.0)].

	41 to: 60 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 40.
		color := color hue: color hue + (360.0 / 120.0)].

	61 to: 80 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 40.
		color := color hue: color hue + (360.0 / 120.0)].

	81 to: 100 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 40.
		color := color hue: color hue + (360.0 / 120.0)].

	101 to: 120 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 40.
		color := color hue: color hue + (360.0 / 120.0)]
 ! !
