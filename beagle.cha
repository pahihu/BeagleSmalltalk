! Integer methodsFor: 'accessing' !
testNestedWhile: aValue
	| i sum |
	i := 0. sum := 0.
	(0 < aValue) ifTrue: [
		[i < aValue] whileTrue: [
			sum := sum + i
		]].
	^sum
	 ! !
