	self selectedKit isNil ifTrue: [^self].
	self selectedKit definedClasses isEmpty ifFalse: [
		self warningMessage: 'Kit isn''t empty - can''t remove'.
		^self].
	KitManager current removeKit: self selectedKit.
	self computeKitList.
	self updateBrowser ! !
