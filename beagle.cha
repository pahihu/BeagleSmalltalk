! MultipleChoiceBox methodsFor: 'building' !
buildOn: aWindowBuilder

	aWindowBuilder
		verticalLayout: '35px 35px 1fr' id: 'messageChoiceDiv';
			horizontalLayout: self messageHorizontalLayoutString id: 'centeringDiv';
				divId: 'centerLeft';
				end;
				textWidget: 'message';
					text: message;
				end;
				divId: 'centerRight';
				end;
			end;
			horizontalLayout: self toolBarHorizontalString id: 'toolBar';
				divId: 'buttonLeftWhitespace';
				end.

	self choices with: self values do: [:choice :value |
			aWindowBuilder
 				pushButton: choice;
					label: choice;
					action: [value value. self close];
				end].

	aWindowBuilder
				divId: 'buttonLeftWhitespace';
				end;
			end;
			divId: 'bottomWhitespace';
			end;
		end  ! !
