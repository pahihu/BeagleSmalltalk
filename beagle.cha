doit ^[JSONLexicalAnalyzer methodsFor: 'parsing'] value ! !
! JSONLexicalAnalyzer methodsFor: 'parsing' !
parseNumber

	| number |
	^self captureOffsetsIn: [number := self readNumber]
		creating: 
			[(number isInteger ifTrue: [IntegerToken new] ifFalse: [FloatToken new])
				value: number;
				yourself] ! !
