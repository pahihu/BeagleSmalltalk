doit ^[PinBoard methodsFor: 'drawing'] value ! !
! PinBoard methodsFor: 'drawing' !
lineToPin: pinNumber

	| nextPin |
	self currentPin isNil ifTrue: [^self].

	nextPin := self pinAt: pinNumber.
	self strings add: (PinString new
		startPin: self currentPin;
		endPin: nextPin;
		color: self currentStringColor;
		yourself).

	self currentPin: nextPin.
	self currentPolygon notNil ifTrue: [currentPolygon moveToPin: self currentPin].

 ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'drawing'] value ! !
! PinBoard methodsFor: 'drawing' !
moveToPin: pinNumber

	self currentPin: (self pinAt: pinNumber).
	self currentPolygon notNil ifTrue: [currentPolygon moveToPin: self currentPin]  ! !
