! WebUI methodsFor: 'opening' !
dragWindow: aDictionary

	| offset |

	dragPoint isNil ifTrue: [^self].

	offset := (aDictionary at: 'pageX') @ (aDictionary at: 'pageY') - (self origin + dragPoint).
	self origin: origin + offset.
	self setAbsoluteWindowBounds ! !
