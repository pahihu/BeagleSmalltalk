classReferencesMenuItem

	^PopupMenuItem new
		id: #classReferences;
		name: 'Class References';
		addRequestedValue: 'pageX';
		addRequestedValue: 'pageY';
		enabledBlock: [self selectedClass notNil];
		action: [:args | self classReferencesWith: args];
		yourself  ! !
