	self runScheduledTasks ! !
! Doit class methodsFor: 'doit' !
doit ^[SocketTimeoutHandler methodsFor: 'handling'] value ! !
! SocketTimeoutHandler methodsFor: 'handling' !
runScheduledTasks

	| task microsecondTime |
	scheduledTasks isEmpty ifTrue: [^self].

	microsecondTime := Time microsecondClockValue.
	[scheduledTasks notEmpty and: [scheduledTasks first time <= microsecondTime]] whileTrue: [
		task := scheduledTasks removeFirst.
		task run] ! !
! Doit class methodsFor: 'doit' !
