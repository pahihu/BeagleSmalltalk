! CanvasChangeFillStyleCommand methodsFor: 'accessing' !
drawOn: aPen

	self fillStyleString = aPen fillStyle ifFalse: [
		aPen setFillStyle: self fillStyleString ].

	 aPen write: 'context.fillStyle = "', self fillStyleString, '";' ! !
