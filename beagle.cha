doit ^[CanvasDrawPathCommand methodsFor: 'rendering'] value ! !
! CanvasDrawPathCommand methodsFor: 'rendering' !
drawOn: aPen

	aPen stream nextPutAll: 'context.beginPath();'; cr.
	self commands do: [:each | each drawOn: aPen].
	aPen stream nextPutAll: 'context.closePath();';
		nextPutAll: (self filled ifTrue: ['context.fill();'] ifFalse: ['context.stroke();']) ;
		cr ! !
