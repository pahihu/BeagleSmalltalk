! WebUI methodsFor: 'closing' !
close

	self preClose.

	WebSession current closeApplication: self.
	self bindings keys do: [:key | (bindings at: key) unbind].

	self runJavaScript: 'document.getElementById("', self appName, '").remove();' ! !
