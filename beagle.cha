! WebUI methodsFor: 'bindings' !
withinWebUpdateDo: aBlock
	| javaScriptString |

	updateStream := WriteStream on: (String new: 1000).
	[
		aBlock value.
		javaScriptString := updateStream contents.
		updateStream := nil.
		self runJavaScript: javaScriptString]
	ensure: [updateStream := nil]
 ! !
