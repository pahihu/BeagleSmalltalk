! Object methodsFor: 'inspecting' !
basicInspectorFields

	| indexedFields |

	indexedFields := OrderedCollection new.
	1 to: (self basicSize min: 500) do: [:each | indexedFields add: each].
	^self class allInstVarNames sorted , indexedFields  ! !
