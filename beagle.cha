! SocketTimeoutHandler methodsFor: 'adding and removing' !
addTask: aScheduledTask

	| index |
	index := scheduledTasks findFirst: [:each | each time >= aScheduledTask time].
	index = 0 ifTrue: [scheduledTasks add: aScheduledTask. ^self].

	scheduledTasks add: aScheduledTask beforeIndex: index ! !
! Doit class methodsFor: 'doit' !
doit ^[SocketTimeoutHandler methodsFor: 'handling'] value ! !
! SocketTimeoutHandler methodsFor: 'handling' !
