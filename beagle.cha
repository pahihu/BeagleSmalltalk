doit ^[CanvasComponent methodsFor: 'initializing'] value ! !
! CanvasComponent methodsFor: 'initializing' !
initialize

	super initialize.
	self backgroundColorString: 'white'.

	self transformation: (TwoDTransformation new
		scale: 2.0 @ -2.0;
		translation: 200.0 @ 200.0;
		computeMatrix;
		yourself).

	self canvasPen: (CanvasPen new
		transformation: self transformation;
		yourself).
  ! !
! Doit class methodsFor: 'doit' !
doit ^[CanvasComponent methodsFor: 'rendering'] value ! !
! CanvasComponent methodsFor: 'rendering' !
canvasStyleString

	^'background-color: ', self backgroundColorString, '; border: 1px solid black;' ! !
! Doit class methodsFor: 'doit' !
doit ^[CanvasComponent methodsFor: 'rendering'] value ! !
! CanvasComponent methodsFor: 'rendering' !
draw

	| canvasBounds |
	canvasBounds := self bounds ifNil: [0@0 extent: 1@1].

	self ui runJavaScript: '{ var canvas = document.getElementById(''', (self ui idFor: 'canvas'), ''');
			canvas.width = ', canvasBounds width printString,';
			canvas.height = ', canvasBounds height printString, ';
			context = canvas.getContext("2d");', self drawCommands, '}' ! !
! Doit class methodsFor: 'doit' !
doit ^[CanvasComponent methodsFor: 'rendering'] value ! !
! CanvasComponent methodsFor: 'rendering' !
drawCommands

	^self canvasPen drawCommands  ! !
! Doit class methodsFor: 'doit' !
doit ^[CanvasComponent methodsFor: 'rendering'] value ! !
! CanvasComponent methodsFor: 'rendering' !
renderOn: anHTMLBuilder

	anHTMLBuilder
		div;
			id: (self id, 'Div');
			bounds: self bounds;
			attributeAt: 'width' put: '100%';
			attributeAt: 'style' put: self styleString.

	self menu isNil ifFalse: [
		anHTMLBuilder
			attributeAt: 'oncontextmenu' put: 'simTalkCallback2(''$', self id , ''', ''openMenuX:y:'', event.pageX, event.pageY); return false;'].

	anHTMLBuilder
			startTag: 'canvas';
				id: (self id);
				attributeAt: 'name' put: self id;
				attributeAt: 'style' put: self canvasStyleString;
			endTag: 'canvas';
		endDiv
    ! !
! Doit class methodsFor: 'doit' !
doit ^[CanvasComponent methodsFor: 'rendering'] value ! !
! CanvasComponent methodsFor: 'rendering' !
resize

	self ui setAttribute: 'style' of: (self id, 'Div') to: self styleString.
	self transformation translation: bounds center - self bounds origin.
	self update ! !
! Doit class methodsFor: 'doit' !
doit ^[CanvasComponent methodsFor: 'rendering'] value ! !
! CanvasComponent methodsFor: 'rendering' !
