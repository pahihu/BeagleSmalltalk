	^HTMLBuilder new
		div: [:builder |
			builder
				id: self innerAppName;
				attributeAt: 'style' put: 'display: grid; grid-template-rows: 200px 400px;';
				div;
					id: (self idFor: 'browserLists');
					attributeAt: 'style' put: 'display: grid; border-bottom: 2px solid #333; display: grid; grid-template-columns: repeat(1, 1fr); background-color: #e9ecef; min-height: 0;overflow: hidden;';
					install: self methodsList;
				endDiv;
				div;
					attributeAt: 'style' put: 'padding: 2px; background-color: #f8f9fa;';
					install: self codeBoxWidget;
				endDiv];
		htmlString ! !
