doit ^[Pin methodsFor: 'displaying'] value ! !
! Pin methodsFor: 'displaying' !
displayPinOn: aPen

	self visible ifFalse: [^self].

	aPen
		fillStyle: self fillColor;
		drawFilledCircleRadius: self radius at: self location;
		strokeStyle: self lineColor;
		drawCircleRadius: self radius at: self location.
  ! !
