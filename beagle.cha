parseOpenBrace

	^self captureOffsetsIn: [self advance]
		creating: [OpenBraceToken new value: ${] ! !
! Doit class methodsFor: 'doit' !
doit ^[JSONLexicalAnalyzer methodsFor: 'parsing'] value ! !
