doit ^[ListChoiceBox methodsFor: 'building'] value ! !
! ListChoiceBox methodsFor: 'building' !
buildOn: aWindowBuilder

	aWindowBuilder
		verticalLayout: '30px 1fr 30px' id: 'messageBoxDiv';
			horizontalLayout: self messageHorizontalLayoutString id: 'centeringDiv';
				divId: 'centerLeft';
				end;
				textWidget: 'messageId';
					text: self message;
				end;
				divId: 'centerRight';
				end;
			end;
			listWidget: #choicesList;
			end;
			horizontalLayout: '5sp 1fr 60px 60px 1fr' id: 'toolBar';
				divId: 'leftWhitespace';
				end;
				pushButton: 'okButton';
					label: 'Ok';
					action: [self okAction];
				end;
				pushButton: 'cancelButton';
					label: 'Cancel';
					action: [self cancelAction];
				end;
				divId: 'rightWhitespace';
				end;
			end;
		end ! !
