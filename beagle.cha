testAtIfAbsent

	| dictionary |
	dictionary := Dictionary new.
	1 to: 5 do: [:i | dictionary at: i printString put: i].

	self
		assert: (dictionary at: 'hello' ifAbsent: ['junk']) = 'junk'
	

 ! !
