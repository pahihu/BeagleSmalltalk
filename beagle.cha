! WindowBuilder methodsFor: 'building' !
canvasWidget: aString

	| widget |
	widget := CanvasComponent new
		bindTo: self window as: aString asSymbol;
		yourself.

	self bindings at: aString asSymbol put: widget.
	self addFrame: (Frame new widget: widget; yourself)

