! PinBoard methodsFor: 'user art' !
hexagonPolygonDoubleArches

	| color |

	self hexagonWithSides: 20.

	color := Color red: 255 green: 0 blue: 0.

	1 to: 20 do: [:each |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: each;
			moveToPin: each + 20;
			moveToPin: each + 40;
			endPolygon.
		color := color hue: color hue + (360.0 / 120.0)].

	21 to: 40 do: [:each |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: each;
			moveToPin: each + 20;
			moveToPin: each + 40;
			endPolygon.
		color := color hue: color hue + (360.0 / 120.0)].

	41 to: 60 do: [:each |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: each;
			moveToPin: each + 20;
			moveToPin: each + 40;
			endPolygon.
		color := color hue: color hue + (360.0 / 120.0)].

	61 to: 80 do: [:each |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: each;
			moveToPin: each + 20;
			moveToPin: each + 40;
			endPolygon.
		color := color hue: color hue + (360.0 / 120.0)].

	81 to: 100 do: [:each |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: each;
			moveToPin: each + 20;
			moveToPin: each + 40;
			endPolygon.
		color := color hue: color hue + (360.0 / 120.0)].

	101 to: 120 do: [:each |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: each;
			moveToPin: each + 20;
			moveToPin: each + 40;
