messageSizeWith: aDictionary

	messageSize := aDictionary at: 'width'.
	self extent: self windowWidth @ self extent y.
	(self frame childNamed: (self idFor: 'centeringDiv')) horizontalChildLayout layoutString: self messageHorizontalLayoutString.
	self resizeFrame ! !
