! WebUI methodsFor: 'running' !
withUIScreen: aScreen do: aBlock

	| oldScreen |
	oldScreen := CurrentScreen.
	CurrentScreen := aScreen.
	aBlock ensure: [
		CurrentScreen := oldScreen]
  ! !
