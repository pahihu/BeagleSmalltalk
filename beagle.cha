! Frame methodsFor: 'rendering' !
renderOn: aBuilder

	self widget notNil ifTrue: [^self widget renderOn: aBuilder].

	aBuilder
		div;
			id: self id.

	self children do: [:child | child renderOn: aBuilder].

	aBuilder endDiv
 ! !
! Doit class methodsFor: 'doit' !
doit ^[Frame methodsFor: 'rendering'] value ! !
! Frame methodsFor: 'rendering' !
resize: aWebUI within: aRectangle

	self bounds: aRectangle.
	self
		resizeDivOn: aWebUI within: aRectangle;
		resizeWidgetOn: aWebUI within: aRectangle;
		resizeChildrenOn: aWebUI within: aRectangle ! !
! Doit class methodsFor: 'doit' !
doit ^[Frame methodsFor: 'rendering'] value ! !
