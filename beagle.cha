doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
mandala

	| interval |

	self clearStrings.
	self circle: 30.

	interval := self pins size // 2.

	interval to: 1 by: -1 do: [:currentInterval |
		1 to: self pins size do: [:start |
			self moveToPin: start.
			self lineToPin: start + currentInterval]].
  ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
pentagonArches

	| color |

	self pentagonWithSides: 20.

	color := Color red: 255 green: 0 blue: 0.

	1 to: 20 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 80.0)].

	21 to: 40 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 80.0)].

	41 to: 60 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 80.0)].

	61 to: 80 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 80.0)].

	81 to: 100 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 80.0)]
 ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
polygonFan

	| color |

	self clearStrings.
	self circle: 80.

	color := Color red: 255 green: 0 blue: 255 alpha: 255.

	2 to: 79 do: [:i |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 1;
			moveToPin: i + 1;
			moveToPin: i + 2;
			endPolygon.
		color := color hue: color hue + (360.0 / 80.0)]

 ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
polygonMandala1

	| color |

	self clearStrings.
	self circle: 80.

	color := Color red: 255 green: 0 blue: 255 alpha: 128.

	1 to: 80 do: [:i |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: i;
			moveToPin: i + 40;
			moveToPin: i + 41;
			endPolygon.
		color := color hue: color hue + (360.0 / 80.0)]

 ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
polygonTwoPointFan

	| color |

	self clearStrings.
	self circle: 80.

	color := Color red: 255 green: 0 blue: 255 alpha: 255.

	2 to: 79 do: [:i |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 1;
			moveToPin: i + 1;
			moveToPin: i + 2;
			endPolygon.
		color := color hue: color hue + (360.0 / 80.0)].

	color := Color red: 0 green: 255 blue: 255 alpha: 128.

	41 to: 119 do: [:i |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 40;
			moveToPin: i + 1;
			moveToPin: i + 2;
			endPolygon.
		color := color copy hue: color hue + (360.0 / 80.0) ]
 ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
rgbMandala

	self clearStrings.
	self circle.

	self color: 'red'.
	1 to: 40 do: [:pin |
		self moveToPin: pin.
		self lineToPin: pin + 9].

	self color: 'blue'.
	1 to: 40 do: [:pin |
		self moveToPin: pin.
		self lineToPin: pin + 19].

	self color: 'green'.
	1 to: 40 do: [:pin |
		self moveToPin: pin.
		self lineToPin: pin + 15]   ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
squareArches

	| color |

	self squareWithSides: 20.

	color := Color red: 255 green: 0 blue: 0.

	1 to: 20 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 80.0)].

	21 to: 40 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 80.0)].

	41 to: 60 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 80.0)].

	61 to: 80 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 80.0)]
 ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
triangleMandala

	| color |

	self clearStrings.
	self circleWithCenter: 80.

	color := Color red: 255 green: 0 blue: 0 alpha: 128.

	1 to: 79 do: [:i |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 81;
			moveToPin: i ;
			moveToPin: i + 20;
			endPolygon.
		color := color hue: color hue + (360.0 / 80.0)].

		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 81;
			moveToPin: 80;
			moveToPin: 21;
			endPolygon.
 ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'user art'] value ! !
! PinBoard methodsFor: 'user art' !
twoPointFan

	self clearStrings.
	self circle: 100.

	self color: 'green'.
	self moveToPin: 1.

	1 to: self pins size do: [:pin |
		self moveToPin: 1.
		self lineToPin: pin].

	self color: 'blue'.
	1 to: self pins size do: [:pin |
		self moveToPin: self pins size // 2 + 1.
		self lineToPin: self pins size // 2 + 1 + pin]  ! !
