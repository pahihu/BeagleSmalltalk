! LexicalAnalyzer methodsFor: 'parsing' !
advance

	next := next2.
	stream atEnd
		ifTrue: [
			next = self finishedCharacter ifFalse: [
				position := position + 1].
			next2 := self finishedCharacter]
		ifFalse: [
			next2 := stream next.
			position := position + 1]. ! !
