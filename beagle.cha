doit ^[CanvasDrawCircleCommand methodsFor: 'initializing'] value ! !
! CanvasDrawCircleCommand methodsFor: 'initializing' !
initialize

	self filled: false ! !
! Doit class methodsFor: 'doit' !
doit ^[CanvasDrawCircleCommand methodsFor: 'rendering'] value ! !
! CanvasDrawCircleCommand methodsFor: 'rendering' !
drawOn: aPen

	| transformedPoint transformedRadius |

	transformedPoint := aPen transformation transform: self center.
	transformedRadius := aPen transformation vectorTransform: self radius @ self radius.

	aPen stream
		nextPutAll: 'context.beginPath();'; cr;
		nextPutAll: 'context.arc(';
		print: transformedPoint x;
		nextPut: $,;
		space;
		print: transformedPoint y;
		nextPut: $,;
		space;
		print: transformedRadius x;
		nextPutAll: ' ,0, 2 * Math.PI);'; cr;
		nextPutAll: (self filled ifTrue: ['context.fill();'] ifFalse: ['context.stroke();']);
		cr
		 ! !
! Doit class methodsFor: 'doit' !
doit ^[CanvasDrawPathCommand methodsFor: 'accessing'] value ! !
