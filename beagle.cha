doit ^[Matrix methodsFor: 'printing'] value ! !
! Matrix methodsFor: 'printing' !
printOn: aStream

	aStream nextPut: $[; cr.

	1 to: self rows do: [:rowNumber |
		1 to: self columns do: [:columnNumber |
			aStream print: (self atRow: rowNumber column: columnNumber); space].
		aStream cr].

	aStream nextPut: $] ! !
