removeIndex: removeIndex

	| index oldValue |

	index := firstIndex - 1 + removeIndex.
	oldValue := values at: index.

	[index < lastIndex]
		whileTrue: 
			[values at: index put: (values at: index+ 1).
			index := index+ 1].
	values at: lastIndex put: nil.
	lastIndex := lastIndex - 1.
