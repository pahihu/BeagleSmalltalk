! ListChoiceBox methodsFor: 'updating' !
okAction

	| index |

	index := (self bindingAt: #choicesList) selectionIndex.

	self close.

	(index >= 0 and: [self answerBlock notNil])
		ifTrue: [self answerBlock value: (self values at: index)].

  ! !
