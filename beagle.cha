! CodeBrowser methodsFor: 'opening' !
postOpen

	super postOpen.

	self browserPlugin
		doPostOpenOn: self.

	self
		withinWebUpdateDo: [
			self update].

	self runJavaScript: 'captureControlKeyInArea("$', self appName ,
		'","s',
		'", "', (self idFor: 'codeTextBoxDiv'),
		'", "', (self idFor: 'codeTextBoxDiv'),
		'", "', #saveCodeWith: , '',
		'", ["innerHTML"]' ,
		');'.
 ! !
