	| value |
	value := aNumber asFloat.
	(self next = $. and: [self next2 isDigit])
		ifTrue: 
			[self advance.
			value := self readDecimalPart: aNumber].
	self next = $e ifFalse: [^value * signNumber].
	self advance.
	^value asFloat * (10 asFloat raisedToInteger: self readExponent) * signNumber ! !
