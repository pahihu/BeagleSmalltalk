		nextPutAll: ''', ''resizeTopRight:'', [''pageX'', ''pageY''], event);'.

	^stream contents     ! !
! Doit class methodsFor: 'doit' !
doit ^[WebUI methodsFor: 'resizing'] value ! !
! WebUI methodsFor: 'resizing' !
resizeTopRightWindow: aDictionary

	| offset oldDragPoint right newExtent left bottom top |

	dragPoint isNil ifTrue: [^self].

	bottom := self origin y + self extent y.

	newExtent := (self minimumSize x max: (aDictionary at: 'pageX') - self origin x) @ (self minimumSize y max: bottom - (aDictionary at: 'pageY')).
	top := bottom - newExtent y.

	self extent: newExtent.
	self origin: origin x @ top.

	self resizeFrame.
	self windowResized      ! !
! Doit class methodsFor: 'doit' !
doit ^[WebUI methodsFor: 'resizing'] value ! !
! WebUI methodsFor: 'resizing' !
resizeTopWindow: aDictionary

	| offset oldDragPoint top newExtent bottom |

	dragPoint isNil ifTrue: [^self].

	bottom := self origin y + self extent y.
	newExtent := self extent x @ (self minimumSize y max: bottom - (aDictionary at: 'pageY')).
	top := bottom - newExtent y.

	self extent: newExtent.
	self origin:  self origin x @ top.

	self resizeFrame.
	self windowResized    ! !
