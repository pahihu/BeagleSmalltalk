! WebUI methodsFor: 'components' !
listDivComponentNamed: aSymbol menu: aMenu

	^self bindingAt: aSymbol ifAbsentPut: [
		ListDivComponent new
			bindTo: self as: aSymbol;
			menu: aMenu;
			yourself]  ! !
