	self class
		openMethodsBrowserOn: (BeagleSystem sendersOf: (self selectedMethod at: 3)) at: (aDictionary at: 'pageX') @ (aDictionary at: 'pageY') title: 'Senders of ', (self selectedMethod at: 3) ! !
