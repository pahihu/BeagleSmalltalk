doit ^[PushButtonComponent methodsFor: 'rendering'] value ! !
! PushButtonComponent methodsFor: 'rendering' !
styleString

	^self bounds isNil
		ifTrue: ['display: grid; align-items: center; text-align: center; background-color: ', self backgroundColor, ';border: 1px black solid;position: absolute;']
		ifFalse: ['cursor: pointer; box-shadow: 0 4px 0 rgba(85,85,85,0.2), inset 0 1px rgba(255,255,255,0.08); display: grid; align-items: center; text-align: center; border-radius: 12px; background: linear-gradient(180deg, color-mix(in srgb, white 80%, #CBB), #CBB);border: 1px black solid; position: absolute; margin: 2px; top: ', (self bounds top) printString, 'px; left: ', (self bounds left) printString, 'px; width: ', (self bounds width) printString, 'px; height: ', (self bounds height - 8) printString, 'px;'.].

 ! !
