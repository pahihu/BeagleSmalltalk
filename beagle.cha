! Pin methodsFor: 'initializing' !
initialize

	self
		lineColor: 'black';
		fillColor: 'black';
		labelColor: 'black';
		radius: 1;
		labelFont: '10px Arial';
		labelOffset: 0 @ 0;
		label: nil;
		visible: true  ! !
