! SmalltalkParser methodsFor: 'building' !
buildBlock: rule

	| newNode |

	newNode := BlockNode new
		scope: scopes last;
		yourself.

	rule sequence do: [:node |
		node isBlockParameterListNode ifTrue: [
			newNode arguments: node].
		(node isKindOf: StatementListNode) ifTrue: [
			newNode statements: node].
		].
	
	^newNode ! !
