! Doit class methodsFor: 'doit' !
doit ^[Layout methodsFor: 'computing'] value ! !
! Layout methodsFor: 'computing' !
componentsWithin: aNumber

	| fractionalSize components total pixels |

	fractionalSize := totalFractionalParts = 0
		ifTrue: [0]
		ifFalse: [aNumber - totalFixedSize // totalFractionalParts].

	total := 0.

	components := OrderedCollection new.

	layoutParts do: [:layoutPart |

		layoutPart first = #fractional ifTrue: [
			layoutPart == layoutParts last
				ifTrue: [pixels := aNumber - total]
				ifFalse: [pixels := fractionalSize * layoutPart last]].

		layoutPart first = #fixed ifTrue: [
			layoutPart == layoutParts last
				ifTrue: [pixels := aNumber - total]
				ifFalse: [pixels := layoutPart last]].

		components add: (Array with: total with: total + pixels - 1).
		total := total + pixels + self spacing].

	^components
	 ! !
! Doit class methodsFor: 'doit' !
doit ^[Layout class methodsFor: 'instance creation'] value ! !
