! Matrix methodsFor: 'printing' !
makeIdentity

	1 to: self rows do: [:rowNumber |
		1 to: self columns do: [:columnNumber |
			self atRow: rowNumber column: columnNumber put: (rowNumber = columnNumber ifTrue: [1.0] ifFalse: [0.0])] ]
 ! !
