    ! !
! Doit class methodsFor: 'doit' !
doit ^[PinBoard methodsFor: 'setting up pins'] value ! !
! PinBoard methodsFor: 'setting up pins' !
circleWithCenter: numberOfPins

	self circleRadius: 80 pins: numberOfPins.
	self addPinAt: 0.0 @ 0.0
    ! !
