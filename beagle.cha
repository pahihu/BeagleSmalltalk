ensureLoaded: aCollection

	self requiredKitNames: aCollection asOrderedCollection.

	aCollection do: [:each |
		(KitManager current hasKitNamed: each) ifFalse: [
			('kits' asFilename construct: (each , '.kit')) fileIn ] ].

	KitManager default currentKit: self
 ! !
