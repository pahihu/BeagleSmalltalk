! SmalltalkParser methodsFor: 'variables' !
findLocalVariableNamed: variableName

	self scopeStack reverseDo: [:scope |
		(scope variableNamed: variableName) ifNotNil: [:variable |
			^scope -> variable]].

	^nil ! !
