! WebUI methodsFor: 'opening' !
open

	WebSession current openApplication: self.

	self build.
	self postBuild.
	self addToInnerHTML: self html.

	self withinWebUpdateDo: [
		self setAbsoluteWindowBounds.
		self resizeFrame].

	self bindings do: [:widget | widget postOpen].
	self postOpen.

	self opened: true  ! !
