! SmalltalkParser class methodsFor: 'evaluating' !
evaluate: aString for: anObject

	| result |

	self
		compile: 'doit ^[', aString, '] value'
		inClass: anObject class
		organization: 'doit'.

	result := anObject perform: #doit.
	anObject class removeSelector: #doit.
	^result  ! !
