! Layout methodsFor: 'accessing' !
computeLayout

	layoutParts := OrderedCollection new.
	totalFractionalParts := 0.
	totalFixedSize := 0.
	self spacing: 0.

	((layoutString splitBy: Character space) reject: [:each | each isEmpty]) do: [:token |
		('*sp' matches: token) ifTrue: [
			| number |
			number := Integer readFrom: token readStream.
			self spacing: number].
		('*fr' matches: token) ifTrue: [
			| number |
			number := Integer readFrom: token readStream.
			layoutParts add: (Array with: #fractional with: number).
			totalFractionalParts := totalFractionalParts + number.
			totalFixedSize := totalFixedSize + self spacing].
		('*px' matches: token) ifTrue: [
			| number |
			number := Integer readFrom: token readStream.
			layoutParts add: (Array with: #fixed with: number).
			totalFixedSize := totalFixedSize + number.
			totalFixedSize := totalFixedSize + self spacing].
		].

	totalFixedSize := totalFixedSize - self spacing max: 0.! !

! Layout methodsFor: 'accessing' !
layoutString: aString

	layoutString := aString.
	self computeLayout! !

! Layout methodsFor: 'accessing' !
spacing

	^spacing! !

! Layout methodsFor: 'accessing' !
spacing: aNumber

	spacing := aNumber! !

! Layout methodsFor: 'computing' !
componentsWithin: aNumber

	| fractionalSize components total pixels |

	fractionalSize := totalFractionalParts = 0
		ifTrue: [0]
		ifFalse: [aNumber - totalFixedSize // totalFractionalParts].

	total := 0.

	components := OrderedCollection new.

	layoutParts do: [:layoutPart |

		layoutPart first = #fractional ifTrue: [
			layoutPart == layoutParts last
				ifTrue: [pixels := aNumber - total]
				ifFalse: [pixels := fractionalSize * layoutPart last]].

		layoutPart first = #fixed ifTrue: [
			layoutPart == layoutParts last
				ifTrue: [pixels := aNumber - total]
				ifFalse: [pixels := layoutPart last]].

		components add: (Array with: total with: total + pixels - 1).
		total := total + pixels + self spacing].

	^components
	! !

