! RichTextEditorComponent methodsFor: 'callbacks' !
captureText: aDictionary

	self setText: (HTMLBuilder new htmlUnquote: (aDictionary at: 'innerHTML')) lfToCR! !

! RichTextEditorComponent methodsFor: 'callbacks' !
debugItWith: aDictionary

	self ui disableWhile: [self
		captureText: aDictionary;
		debugItFrom: (aDictionary at: 'richTextSelectionStart') + 1 to: (aDictionary at: 'richTextSelectionEnd') onError: [^self]]  ! !

! RichTextEditorComponent methodsFor: 'callbacks' !
doItWith: aDictionary

	self ui disableWhile: [self
		captureText: aDictionary;
		evaluateFrom: (aDictionary at: 'richTextSelectionStart') + 1 to: (aDictionary at: 'richTextSelectionEnd') onError: [^self]]  ! !

