! WebUI methodsFor: 'accessing' !
frame

	^frame! !

! WebUI methodsFor: 'accessing' !
frame: anObject

	frame := anObject! !

! WebUI methodsFor: 'accessing' !
htmlTree

	^htmlTree! !

! WebUI methodsFor: 'accessing' !
htmlTree: anObject

