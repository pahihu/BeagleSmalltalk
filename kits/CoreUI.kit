inspectItWith: aDictionary

	self ui disableWhile: [self
		captureText: aDictionary;
		inspectItFrom: (aDictionary at: 'richTextSelectionStart') + 1 to: (aDictionary at: 'richTextSelectionEnd') onError: [^self]]  ! !

