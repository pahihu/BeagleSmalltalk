triangleVertices

	^(Array new: 12)
		at: 1 put: origin x;
		at: 2 put: corner y;
		at: 3 put: origin x;
		at: 4 put: origin y;
		at: 5 put: corner x;
		at: 6 put: origin y;
		at: 7 put: origin x;
		at: 8 put: corner y;
		at: 9 put: corner x;
		at: 10 put: origin y;
		at: 11 put: corner x;
		at: 12 put: corner y;
		yourself! !

