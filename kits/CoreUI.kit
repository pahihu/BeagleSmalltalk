id

	^id! !

! Frame methodsFor: 'accessing' !
id: anObject

	id := anObject! !

! Frame methodsFor: 'accessing' !
idOrWidgetId

	self id notNil ifTrue: [^self id].
	self widget notNil ifTrue: [^self widget id, 'Div'].
	^''! !

! Frame methodsFor: 'accessing' !
parent

	^parent! !

! Frame methodsFor: 'accessing' !
parent: anObject

	parent := anObject! !

! Frame methodsFor: 'accessing' !
verticalChildLayout

