resize

	self ui setAttribute: 'style' of: (self id, 'Div') to: self styleString.
	self updateForResize
! !

! ListDivComponent methodsFor: 'rendering' !
styleString

	^self bounds isNil
		ifTrue: ['border: 1px black solid;min-height: 0;overflow: auto;']
		ifFalse: ['border: 1px black solid;min-height: 0;position: absolute; top: ', (self bounds top) printString, 'px; left: ', (self bounds left) printString, 'px; width: ', (self bounds width) printString, 'px; height: ', (self bounds height) printString, 'px;'.].
! !

! ListDivComponent methodsFor: 'updating' !
doubleClickCallbackString: itemName

	^'simTalkCallback1(''$', self id , ''', ''doubleClickWith:'' , ''', itemName, ''');'

! !

! ListDivComponent methodsFor: 'updating' !
optionStyleFor: index

	self optionStyles isNil ifTrue: [^''].
	self optionStyles size >= index ifFalse: [^''].
	^self optionStyles at: index
! !

! ListDivComponent methodsFor: 'updating' !
scrollToSelection

	self ui setAttribute: 'scrollTop' of: self scrollableDivName to: ((scrollHeight - self bounds height + 20) * ((self selectionIndex - 1) asFloat / self list size asFloat)) asInteger printString ! !

! ListDivComponent methodsFor: 'updating' !
scrollableDivName

	^self id , '-scrollableDiv'! !

! ListDivComponent methodsFor: 'updating' !
selectItemCallbackString: itemName

	^'simTalkCallback1(''$', self id , ''', ''changedSelectedItem:'' , ''', itemName, ''');'

! !

! ListDivComponent methodsFor: 'updating' !
update

	self updateList! !

! ListDivComponent methodsFor: 'updating' !
updateForResize

	| style |

	listRendered ifFalse: [^self updateList].

	style := self bounds isNil
			ifTrue: ['min-height: 0;overflow: auto;']
			ifFalse: ['padding: 2px; min-height: 0;overflow: auto;position: absolute; width: ', (self bounds width - 4) printString, 'px; height: ', (self bounds height - 4) printString, 'px;'.].
	self ui setAttribute: 'style' of: self scrollableDivName to: style
! !

! ListDivComponent methodsFor: 'updating' !
updateList

	| htmlBuilder |

	self list isNil ifTrue: [^self].

	htmlBuilder := HTMLBuilder new.

	htmlBuilder div: [:builder1 |
		self bounds isNil
			ifTrue: [builder1 attributeAt: 'style' put: 'min-height: 0;overflow: auto;']
			ifFalse: [builder1 attributeAt: 'style' put: 'padding: 2px; min-height: 0;overflow: auto;position: absolute; width: ', (self bounds width - 4) printString, 'px; height: ', (self bounds height - 4) printString, 'px;'.].

		builder1 attributeAt: 'id' put: self scrollableDivName.
		builder1 attributeAt: 'onscroll' put: ('simTalkCallback1(''$', self id , ''', ''scrolled:'', document.getElementById(''', self scrollableDivName , ''').scrollTop);').

		self list keysAndValuesDo: [:key :eachElement |
			builder1 div: [:builder2 |
				| optionStyle |
				builder2 id: self id, '-', key printString.
				optionStyle := (self optionStyleFor: key) , 'cursor: default;'.
				key = self selectionIndex
					ifTrue: [builder2 attributeAt: 'style' put: optionStyle, 'background-color: #C0C0FF;']
					ifFalse: [optionStyle isEmpty ifFalse: [builder2 attributeAt: 'style' put: optionStyle]].
				builder2 attributeAt: 'onclick' put: (self selectItemCallbackString: key printString).
				builder2 attributeAt: 'ondblclick' put: (self doubleClickCallbackString: key printString).
				builder2 text: (self displayBlock isNil ifTrue: [eachElement] ifFalse: [self displayBlock value: eachElement]) displayString
				]]].

	self ui setInnerHTMLOf: (self id, 'Div') to: (self ui javascriptQuote: htmlBuilder htmlString).
	self scrollTop notNil ifTrue: [
		self ui setAttribute: 'scrollTop' of: self scrollableDivName to: self scrollTop printString].

	self ui runJavaScript: 'simTalkCallback1(''$', self id , ''', ''scrollHeightWith:'', document.getElementById(''', self scrollableDivName , ''').scrollHeight);'.
	listRendered := true
  ! !

! ListDivComponent methodsFor: 'updating' !
updateSelectionIndex

	self updateList
! !

