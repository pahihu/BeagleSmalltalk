onClicked: aSymbol

	self currentFrame widget onClicked: aSymbol! !

! WindowBuilder methodsFor: 'building' !
onDoubleClick: aSymbol

	self currentFrame widget
		onEvent: DoubleClickEvent do: [:event | window perform: aSymbol asSymbol with: event]

 ! !

! WindowBuilder methodsFor: 'building' !
onSelection: aSymbol

	self currentFrame widget
		onSelection: aSymbol;
		onEvent: ListSelectionEvent do: [:event | self window perform: aSymbol asSymbol with: event]

! !

