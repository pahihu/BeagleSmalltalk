		div;
			id: (self id);
			attributeAt: 'class' put: 'button';
			attributeAt: 'tabIndex' put: '2';
			attributeAt: 'onclick' put: 'simTalkCallback0(''$', self id , ''', ''pressAction'');';
			attributeAt: 'style' put: 'align-self: center;';
