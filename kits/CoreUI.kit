bounds

	^bounds! !

! Frame methodsFor: 'accessing' !
bounds: anObject

	bounds := anObject! !

! Frame methodsFor: 'accessing' !
childNamed: aString

	self id = aString ifTrue: [^self].

	self children do: [:child |
		(child childNamed: aString) ifNotNil: [^child]].

	^nil! !

! Frame methodsFor: 'accessing' !
children

	^children! !

! Frame methodsFor: 'accessing' !
children: anObject

	children := anObject! !

