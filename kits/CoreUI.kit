! RichTextEditorComponent methodsFor: 'evaluating' !
debugItFrom: start to: end onError: aBlock

	^self evaluate: ('[', (self text copyFrom: start to: end), '] halt; value' ) from: start to: end onError: aBlock! !

! RichTextEditorComponent methodsFor: 'evaluating' !
evaluate: aString from: start to: end onError: aBlock

	^[SmalltalkParser evaluate: aString for: self subject]
		on: CompileError
		do: [:ex |
 			| convertedString endOffset code |
			convertedString := self text lfToCR.

			"The 7 skips past the doit ^[ added in by the evaluate"
			endOffset := start + (ex endSourceOffset - 7 + 1 min: convertedString size).

			code :=
				(convertedString copyFrom: 1 to: endOffset),
				' ' , ex message asString, ' ',
				(convertedString copyFrom: endOffset + 1 to: convertedString size).

			self
				text: code;
				updateText;
				setSelectionFrom: endOffset to: endOffset + 2 + ex message asString size.
 			aBlock value] ! !

! RichTextEditorComponent methodsFor: 'evaluating' !
evaluateAll

	^self evaluateFor: self subject 

! !

! RichTextEditorComponent methodsFor: 'evaluating' !
evaluateFor: anObject

	^[SmalltalkParser evaluate: self text for: anObject]
		on: CompileError
		do: [:ex |
 			| convertedString endOffset code |
			convertedString := self text lfToCR.

			"The 7 skips past the doit ^[ added in by the evaluate"
			endOffset := ex endSourceOffset - 7 + 1 min: convertedString size.

			code :=
				(convertedString copyFrom: 1 to: endOffset),
				' ' , ex message asString, ' ',
				(convertedString copyFrom: endOffset + 1 to: convertedString size).

			self
				text: code;
				updateText;
				setSelectionFrom: endOffset to: endOffset + 2 + ex message asString size.
 			ex return: nil]! !

! RichTextEditorComponent methodsFor: 'evaluating' !
evaluateFrom: start to: end onError: aBlock

	^self evaluate: (self text copyFrom: start to: end) from: start to: end onError: aBlock! !

! RichTextEditorComponent methodsFor: 'evaluating' !
inspectFrom: start to: end onError: aBlock

	^(self evaluateFrom: start to: end onError: aBlock) inspect ! !

! RichTextEditorComponent methodsFor: 'evaluating' !
inspectItFrom: start to: end onError: aBlock

	^(self evaluateFrom: start to: end onError: aBlock) inspect ! !

! RichTextEditorComponent methodsFor: 'evaluating' !
printItFrom: start to: end onError: aBlock

	| result string |

	result := self evaluateFrom: start to: end onError: aBlock.
	string := ' ==> ', result printString.

	self ui runJavaScript: 'insertRichText("' , self id , '", "', (self ui javascriptQuote: string), '",',  end printString, ');'.
	self setSelectionFrom: end to: end + string size ! !

! RichTextEditorComponent methodsFor: 'evaluating' !
timeItFrom: start to: end onError: aBlock

	^self evaluate: ('MessageBox message: (Time microsecondsToRun: [', (self text copyFrom: start to: end), ']) printString , '' microseconds''' ) from: start to: end onError: aBlock! !

! RichTextEditorComponent methodsFor: 'initializing' !
initialize

	super initialize.
	self
		text: '';
		selectionStart: 0;
		selectionEnd: 0;
		emphasisCollection: OrderedCollection new
! !

! RichTextEditorComponent methodsFor: 'menus' !
inspectItMenuItem

	^PopupMenuItem new
			id: #inspectIt;
			name: 'Inspect It';
			action: [:args | self inspectItWith: args];
			requestedValues: #('selectedString');
			yourself! !

! RichTextEditorComponent methodsFor: 'menus' !
load: aString

	| workspaceContents fileStream |

	aString isNil ifTrue: [^self].
	aString asFilename exists ifFalse: [^self message: 'File doesn''t exist'].

	fileStream := aString asFilename readStream.
	workspaceContents := fileStream upToEnd.
	fileStream close.

	self
		clearEmphasis;
		text: workspaceContents;
		updateText! !

! RichTextEditorComponent methodsFor: 'menus' !
loadMenuItem

	^PopupMenuItem new
		id: #load;
		name: 'Load...';
		action: [:args | self loadWith: args];
		requestedValues: #();
		yourself! !

! RichTextEditorComponent methodsFor: 'menus' !
loadWith: aDictionary

	self request: 'Filename to load?' initialAnswer: 'workspace.ws' answerBlock: [:string | self load: string]! !

! RichTextEditorComponent methodsFor: 'menus' !
printItMenuItem

	^PopupMenuItem new
		id: #printIt;
		name: 'Print It';
		action: [:args | self printItWith: args];
		requestedValues: #('richTextSelectionStart' 'richTextSelectionEnd');
		yourself ! !

! RichTextEditorComponent methodsFor: 'menus' !
save: aString to: filenameString

	| file |

	file := filenameString asFilename writeStream.
	file nextPutAll: aString.
	file close
! !

! RichTextEditorComponent methodsFor: 'menus' !
saveMenuItem

	^PopupMenuItem new
		id: #save;
		name: 'Save...';
		action: [:args | self saveWith: args];
		requestedValues: #('innerHTML');
		yourself! !

! RichTextEditorComponent methodsFor: 'menus' !
saveWith: aDictionary

	self request: 'Filename to save?' initialAnswer: 'workspace.ws' answerBlock: [:string | self save: (aDictionary at: 'value') to: string]! !

! RichTextEditorComponent methodsFor: 'rendering' !
divStyleString

	| widthString heightString |

	widthString := self bounds isNil
		ifTrue: ['100%']
		ifFalse: [(self bounds width - 4) printString , 'px'].

	heightString := self bounds isNil
		ifTrue: ['100%']
		ifFalse: [(self bounds height - 4) printString , 'px'].

	^'border: 1px solid black; padding: 2px; overflow-y: scroll;' ,
					';background-color: transparent; resize: none; white-space:pre-wrap; font-family:arial; font-size:14px;line-height:1.4;' ,
					'width: ', widthString, '; height: ' , heightString, ';'! !

! RichTextEditorComponent methodsFor: 'rendering' !
postOpen

	self ui runJavaScript: 'enableTabsInRichTextArea("', self id, '");'.

	self ui runJavaScript: 'captureControlKeyInArea("$', self id,
		'","d',
		'", "', self id,
		'", "', self id,
		'", "', #doItWith: , '',
		'", ["richTextSelectionStart", "richTextSelectionEnd", "innerHTML"]' ,
		');'.

	self ui runJavaScript: 'captureControlKeyInArea("$', self id,
		'","p',
		'", "', self id,
		'", "', self id,
		'", "', #printItWith: , '',
		'", ["richTextSelectionStart", "richTextSelectionEnd", "innerHTML"]' ,
		');'.

	self ui runJavaScript: 'captureControlKeyInArea("$', self id,
		'","q',
		'", "', self id,
		'", "', self id,
		'", "', #inspectItWith: , '',
		'", ["richTextSelectionStart", "richTextSelectionEnd", "innerHTML"]' ,
		');'.

	self ui runJavaScript: 'captureControlKeyInArea("$', self id,
		'","b',
		'", "', self id,
		'", "', self id,
		'", "', #debugItWith: , '',
		'", ["richTextSelectionStart", "richTextSelectionEnd", "innerHTML"]' ,
		');'.

	self ui runJavaScript: 'captureControlKeyInArea("$', self id,
		'","k',
		'", "', self id,
		'", "', self id,
		'", "', #timeItWith: , '',
		'", ["richTextSelectionStart", "richTextSelectionEnd", "innerHTML"]' ,
		');'.

! !

! RichTextEditorComponent methodsFor: 'rendering' !
renderOn: anHTMLBuilder

	anHTMLBuilder
		div;
			id: (self id, 'Div');
			bounds: self bounds;
			attributeAt: 'width' put: '100%'.

	self menu isNil ifFalse: [
		anHTMLBuilder
			attributeAt: 'oncontextmenu'
			put: 'simTalkCallback2(''$', self id , ''', ''openMenuX:y:'', event.pageX, event.pageY); return false;'].

	anHTMLBuilder
			startTag: 'div';
				id: (self id);
				attributeAt: 'contenteditable' put: 'true';
				attributeAt: 'name' put: self id;
				attributeAt: 'width' put: '100%';
				attributeAt: 'spellcheck' put: 'false';
				attributeAt: 'style' put: self divStyleString;
				attributeAt: 'tabIndex' put: '2';
				attributeAt: 'onfocusout' put: 'requestedFieldsCallbackNoCapture(''$', self id , ''', ''nil'', ''', self id , ''', ''captureText:'', [''innerHTML'']);'.

		anHTMLBuilder
			endTag: 'div';
		endDiv ! !

! RichTextEditorComponent methodsFor: 'rendering' !
resize

	self ui setAttribute: 'style' of: self id to: self divStyleString! !

! RichTextEditorComponent methodsFor: 'updating' !
quotedText

	| in out mappings emphasisStream |
	in := self text readStream.
	out := WriteStream on: (String new: self text size).
	mappings := Dictionary new.
	mappings
		at: $\ put: '\\';
		at: Character cr put: '\r\n';
		at: Character tab put: '\t';
		at: $< put: '&lt;';
		at: $> put: '&gt;';
		at: $& put: '&amp;';
		at: $" put: '\"';
		at: $' put: '&apos;'.

	emphasisStream := EmphasisStream on: emphasisCollection.

	[in atEnd] whileFalse: [
		| character replacement |
		character := in next.

		emphasisStream writeEmphasisOn: out forIndex: in position.

		replacement := mappings at: character ifAbsent: [nil].
		replacement isNil
			ifTrue: [out nextPut: character]
			ifFalse: [out nextPutAll: replacement]].

	emphasisStream writeEmphasisOn: out forIndex: in position.

	^out contents! !

! RichTextEditorComponent methodsFor: 'updating' !
setSelectionFrom: startOffset to: endOffset

	self ui runJavaScript: 'setSelectionByAbsoluteOffsets(''', self id , ''',' , startOffset printString, ',' , endOffset printString, ');'.! !

! RichTextEditorComponent methodsFor: 'updating' !
updateText

	self ui isNil ifTrue: [^self].

	self ui setInnerHTMLOf: self id to: self quotedText! !

