! Frame methodsFor: 'accessing' !
verticalChildLayout: aString

	verticalChildLayout := Layout layoutString: aString! !

! Frame methodsFor: 'accessing' !
widget

	^widget! !

! Frame methodsFor: 'accessing' !
widget: anObject

	widget := anObject.
	anObject frame: self! !

! Frame methodsFor: 'adding and removing' !
addChild: aFrame

	self children add: aFrame.
	^aFrame! !

! Frame methodsFor: 'initializing' !
initialize

	self
		children: OrderedCollection new! !

! Frame methodsFor: 'printing' !
printOn: aStream

	super printOn: aStream.
	self verticalChildLayout isNil & self horizontalChildLayout isNil & self widget isNil ifTrue: [^self].

	aStream nextPutAll: ' ('.
	self verticalChildLayout  notNil ifTrue: [
		aStream
			nextPutAll: 'vertical: ''';
			nextPutAll: self verticalChildLayout printString;
			space].

	self horizontalChildLayout notNil ifTrue: [
		aStream
			nextPutAll: 'horizontal: ''';
			nextPutAll: self horizontalChildLayout printString;
			space].

	self widget notNil ifTrue: [
		aStream
			nextPutAll: 'widget: ';
			nextPutAll: self widget printString;
			space].

	aStream nextPut: $)
		! !

! Frame methodsFor: 'rendering' !
layoutChildrenHorizontallyOn: aWebUI within: aRectangle

	self children with: (self horizontalChildLayout componentsWithin: aRectangle width) do: [:child :component |
		| box |
		box := component first @ 0 extent: (component last - component first) @ aRectangle height.
		child resize: aWebUI within: box].
 
"	self children with: (self horizontalChildLayout componentsWithin: aRectangle width) do: [:child :component |
		| box |
		box := component first @ aRectangle top corner: component last @ aRectangle bottom.
		child resize: aWebUI within: box].
 "! !

! Frame methodsFor: 'rendering' !
layoutChildrenVerticallyOn: aWebUI within: aRectangle

	self children with: (self verticalChildLayout componentsWithin: aRectangle height) do: [:child :component |
		| box |
		box := 0 @ component first extent: aRectangle width @ (component last - component first).
		child resize: aWebUI within: box].
 
"	self children with: (self verticalChildLayout componentsWithin: aRectangle height) do: [:child :component |
		| box |
		box := aRectangle left @ component first corner: aRectangle right @ component last.
		child resize: aWebUI within: box].
 "! !

! Frame methodsFor: 'rendering' !
layoutStringFor: aWebUI within: aRectangle

	^(WriteStream on: (String new: 1000))
		nextPutAll: 'position: absolute; left: ';
		print: aRectangle left;
		nextPutAll: 'px; width:';
		print: aRectangle width;
		nextPutAll: 'px; height: ';
		print: aRectangle height;
		nextPutAll: 'px; top: ';
		print: aRectangle top;
		nextPutAll: 'px;';
		contents
! !

! Frame methodsFor: 'rendering' !
renderOn: aBuilder

	self widget notNil ifTrue: [^self widget renderOn: aBuilder].

	aBuilder
		div;
			id: self id.

	self children do: [:child | child renderOn: aBuilder].

	aBuilder endDiv
! !

! Frame methodsFor: 'rendering' !
resize: aWebUI within: aRectangle

	self bounds: aRectangle.
	self
		resizeDivOn: aWebUI within: aRectangle;
		resizeWidgetOn: aWebUI within: aRectangle;
		resizeChildrenOn: aWebUI within: aRectangle! !

! Frame methodsFor: 'rendering' !
resizeChildrenOn: aWebUI within: aRectangle

	self horizontalChildLayout notNil ifTrue: [^self layoutChildrenHorizontallyOn: aWebUI within: aRectangle].
	self verticalChildLayout notNil ifTrue: [^self layoutChildrenVerticallyOn: aWebUI within: aRectangle]
! !

! Frame methodsFor: 'rendering' !
resizeDivOn: aWebUI within: aRectangle

	aWebUI setAttribute: 'style' of: self idOrWidgetId to: (self layoutStringFor: aWebUI within: aRectangle)
	
  ! !

! Frame methodsFor: 'rendering' !
resizeWidgetOn: aWebUI within: aRectangle

	self widget isNil ifTrue: [^self].

	widget
		bounds: (aRectangle origin extent: (aRectangle width @ aRectangle height));
		resize
  ! !

! Frame class methodsFor: 'instance creation' !
new

	^super new initialize; yourself! !

! HTMLBuilder methodsFor: 'accessing' !
currentNode

	^currentNode! !

! HTMLBuilder methodsFor: 'accessing' !
currentNode: anObject

	currentNode := anObject! !

