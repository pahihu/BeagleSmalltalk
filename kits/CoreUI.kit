resizeBottomRightCallback

	| stream |

	stream := WriteStream on: (String new: 40).
	stream
		nextPutAll: 'requestedFieldsCallback(''$', self appName, ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''resizeBottomRight:'', [''pageX'', ''pageY''], event);'.

	^stream contents  ! !

! WebUI methodsFor: 'resizing' !
resizeBottomRightWindow: aDictionary

	| offset oldDragPoint |

	dragPoint isNil ifTrue: [^self].

	offset := (aDictionary at: 'pageX')  - self origin x @ ((aDictionary at: 'pageY') - self origin y).
	self extent: (self minimumSize max: offset).

	self resizeFrame.
	self windowResized  ! !

! WebUI methodsFor: 'resizing' !
resizeBottomWindow: aDictionary

	| offset oldDragPoint |

	dragPoint isNil ifTrue: [^self].

	offset := self extent x @ ((aDictionary at: 'pageY')  - self origin y).
	self extent: (self minimumSize max: offset).

	self resizeFrame.
	self windowResized ! !

! WebUI methodsFor: 'resizing' !
resizeDivOn: anHTMLBuilder

	| width height |
	width := self extent isNil ifTrue: [10] ifFalse: [self extent x].
	height := self extent isNil ifTrue: [10] ifFalse: [self extent y].

	anHTMLBuilder
		div: [:b |
			b attributeAt: 'id' put: (self idFor: 'resizeDiv');
			div: [:builder |
				builder
					attributeAt: 'id' put: (self idFor: 'rightResize');
					attributeAt: 'style' put: self rightResizeStyle;
					attributeAt: 'onmousedown' put: self resizeRightCallback];

			div: [:builder |
				builder
					attributeAt: 'id' put: (self idFor: 'leftResize');
					attributeAt: 'style' put: self leftResizeStyle;
					attributeAt: 'onmousedown' put: self resizeLeftCallback];
			div: [:builder |
				builder
					attributeAt: 'id' put: (self idFor: 'topResize');
					attributeAt: 'style' put: self topResizeStyle;
					attributeAt: 'onmousedown' put: self resizeTopCallback];
			div: [:builder |
				builder
					attributeAt: 'id' put: (self idFor: 'bottomResize');
					attributeAt: 'style' put: self bottomResizeStyle;
					attributeAt: 'onmousedown' put: self resizeBottomCallback];
			div: [:builder |
				builder
					attributeAt: 'id' put: (self idFor: 'bottomRightResize');
					attributeAt: 'style' put: self bottomRightResizeStyle;
					attributeAt: 'onmousedown' put: self resizeBottomRightCallback];
			div: [:builder |
				builder
					attributeAt: 'id' put: (self idFor: 'bottomLeftResize');
					attributeAt: 'style' put: self bottomLeftResizeStyle;
					attributeAt: 'onmousedown' put: self resizeBottomLeftCallback];
			div: [:builder |
				builder
					attributeAt: 'id' put: (self idFor: 'topLeftResize');
					attributeAt: 'style' put: self topLeftResizeStyle;
					attributeAt: 'onmousedown' put: self resizeTopLeftCallback];
			div: [:builder |
				builder
					attributeAt: 'id' put: (self idFor: 'topRightResize');
					attributeAt: 'style' put: self topRightResizeStyle;
					attributeAt: 'onmousedown' put: self resizeTopRightCallback] ]
! !

! WebUI methodsFor: 'resizing' !
resizeFrame

	self frame isNil ifTrue: [^self].
	self
		setAbsoluteWindowBounds;
		setAttribute: 'style' of: (self idFor: 'enableDisable') to: self enableDisableStyle;
		setAttribute: 'style' of: (self idFor: 'rightResize') to: self rightResizeStyle;
		setAttribute: 'style' of: (self idFor: 'leftResize') to: self leftResizeStyle;
		setAttribute: 'style' of: (self idFor: 'topResize') to: self topResizeStyle;
		setAttribute: 'style' of: (self idFor: 'bottomResize') to: self bottomResizeStyle;
		setAttribute: 'style' of: (self idFor: 'bottomRightResize') to: self bottomRightResizeStyle;
		setAttribute: 'style' of: (self idFor: 'bottomLeftResize') to: self bottomLeftResizeStyle;
		setAttribute: 'style' of: (self idFor: 'topLeftResize') to: self topLeftResizeStyle;
		setAttribute: 'style' of: (self idFor: 'topRightResize') to: self topRightResizeStyle.

	self frame resize: self within: self bounds


    ! !

