! WebUI methodsFor: 'resizing' !
bottomRightResizeStyle

	| width height |
	width := self extent isNil ifTrue: [10] ifFalse: [self extent x].
	height := self extent isNil ifTrue: [10] ifFalse: [self extent y].

	^'cursor: nwse-resize; position: absolute; border: none; left: ',
					(width - 4) printString, 'px; width: 4px;top: ', (height - 4) printString,'px; height: 4px;'   ! !

! WebUI methodsFor: 'resizing' !
leftResizeDiv

	^HTMLBuilder new
		div: [:builder |
			builder
				attributeAt: 'id' put: (self idFor: 'windowDrag');
				attributeAt: 'style' put: 'position: absolute; top: 0; bottom: 0; width: 3000px; height: 2000px; background-color: transparent;';
				attributeAt: 'onmousemove' put: self leftResizeMouseMoveCallbackString;
				attributeAt: 'onmouseup' put: self bottomRightResizeMouseUpCallbackString];
		htmlString  ! !

! WebUI methodsFor: 'resizing' !
leftResizeMouseMoveCallbackString

	| stream |

	stream := WriteStream on: (String new: 40).
	stream
		nextPutAll: 'requestedFieldsCallback(''$', self appName, ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''resizeLeftWindow:'', [''pageX'', ''pageY''], event);'.

	^stream contents  ! !

! WebUI methodsFor: 'resizing' !
leftResizeStyle

	| height |
	height := self extent isNil ifTrue: [10] ifFalse: [self extent y].

	^'cursor: ew-resize; position: absolute; border: none; left: 0px; width: 2px; top: 2px; height: ', (height - 4) printString, 'px;'  ! !

! WebUI methodsFor: 'resizing' !
minimumSize

	^400 @ 200! !

! WebUI methodsFor: 'resizing' !
resizeBottom: aDictionary

	dragPoint := (aDictionary at: 'pageX') @ (aDictionary at: 'pageY') - self origin.
	self addHTMLBeforeEndOf: self rootName to: self bottomResizeDiv ! !

! WebUI methodsFor: 'resizing' !
resizeBottomCallback

	| stream |

	stream := WriteStream on: (String new: 40).
	stream
		nextPutAll: 'requestedFieldsCallback(''$', self appName, ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''resizeBottom:'', [''pageX'', ''pageY''], event);'.

	^stream contents ! !

! WebUI methodsFor: 'resizing' !
resizeBottomLeft: aDictionary

	dragPoint := (aDictionary at: 'pageX') @ (aDictionary at: 'pageY') - self origin.
	self addHTMLBeforeEndOf: self rootName to: self bottomLeftResizeDiv  ! !

! WebUI methodsFor: 'resizing' !
resizeBottomLeftCallback

	| stream |

	stream := WriteStream on: (String new: 40).
	stream
		nextPutAll: 'requestedFieldsCallback(''$', self appName, ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''';
		nextPutAll: self appName;
		nextPutAll: ''', ''resizeBottomLeft:'', [''pageX'', ''pageY''], event);'.

	^stream contents  ! !

! WebUI methodsFor: 'resizing' !
resizeBottomLeftWindow: aDictionary

	| offset oldDragPoint right newExtent left |

	dragPoint isNil ifTrue: [^self].

	right := self origin x + self extent x.
	newExtent := (self minimumSize x max: right - (aDictionary at: 'pageX')) @ ((aDictionary at: 'pageY') - self origin y).
	left := right - newExtent x.

	self extent: newExtent.
	self origin:  left @ self origin y.

	self resizeFrame.
	self windowResized   ! !

! WebUI methodsFor: 'resizing' !
resizeBottomRight: aDictionary

	dragPoint := (aDictionary at: 'pageX') @ (aDictionary at: 'pageY') - self origin.
	self addHTMLBeforeEndOf: self rootName to: self bottomRightResizeDiv  ! !

