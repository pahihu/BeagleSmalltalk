window

	^window! !

! WindowBuilder methodsFor: 'accessing' !
window: anObject

	window := anObject! !

! WindowBuilder methodsFor: 'building' !
action: aBlock
	self currentFrame widget actionBlock: aBlock! !

! WindowBuilder methodsFor: 'building' !
addFrame: aFrame

	self currentFrame isNil
		ifTrue: [self rootFrame: aFrame]
		ifFalse: [self currentFrame addChild: aFrame].

	aFrame parent: self currentFrame.
	self currentFrame: aFrame
	
	! !

! WindowBuilder methodsFor: 'building' !
divId: id

	self addFrame: (Frame new
		id: (self window idFor: id);
		parent: self currentFrame;
		yourself)
	! !

! WindowBuilder methodsFor: 'building' !
end

	self currentFrame: self currentFrame parent! !

! WindowBuilder methodsFor: 'building' !
horizontalLayout: aString id: id

	self addFrame: (Frame new
		id: (self window idFor: id);
		horizontalChildLayout: aString;
		parent: self currentFrame;
		yourself)
	! !

! WindowBuilder methodsFor: 'building' !
inputFieldWidget: aString

	| widget |
	widget := InputFieldComponent new
		bindTo: self window as: aString asSymbol;
		yourself.

	self bindings at: aString asSymbol put: widget.
	self addFrame: (Frame new widget: widget; yourself)

! !

! WindowBuilder methodsFor: 'building' !
label: aString

	self currentFrame widget label: aString! !

! WindowBuilder methodsFor: 'building' !
listWidget: aString

	| widget |
	widget := ListDivComponent new
		bindTo: self window as: aString asSymbol;
		yourself.

	self bindings at: aString asSymbol put: widget.
	self addFrame: (Frame new widget: widget; yourself)

! !

