appName

	^appName! !

! WebUI methodsFor: 'accessing' !
appName: anObject

	appName := anObject! !

! WebUI methodsFor: 'accessing' !
bindings

	^bindings! !

! WebUI methodsFor: 'accessing' !
bindings: anObject

	bindings := anObject! !

! WebUI methodsFor: 'accessing' !
bounds

	^0 @ 35 corner: self extent! !

! WebUI methodsFor: 'accessing' !
extent

	^extent! !

! WebUI methodsFor: 'accessing' !
extent: aPoint

	extent := aPoint! !

! WebUI methodsFor: 'accessing' !
flags

	^flags! !

! WebUI methodsFor: 'accessing' !
flags: aSet

