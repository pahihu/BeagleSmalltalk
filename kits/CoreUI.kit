subject: anObject

	self currentFrame widget subject: anObject ! !

! WindowBuilder methodsFor: 'building' !
text: aString

	self currentFrame widget text: aString! !

! WindowBuilder methodsFor: 'building' !
textWidget: aString

	| widget |
	widget := TextComponent new
		bindTo: self window as: aString asSymbol;
