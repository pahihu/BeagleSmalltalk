verticalLayout: aString id: id

	self addFrame: (Frame new
		id: (self window idFor: id);
		verticalChildLayout: aString;
		parent: self currentFrame;
		yourself)
	! !

! WindowBuilder methodsFor: 'initializing' !
initialize

	self bindings: Dictionary new
! !

! WindowBuilder methodsFor: 'installing' !
installOn: aWindow

	aWindow frame: self rootFrame.
	self bindings keysAndValuesDo: [:key :value |
		aWindow bindingAt: key put: value].
! !

! WindowBuilder class methodsFor: 'instance creation' !
new

	^super new initialize; yourself! !

! WindowBuilder class methodsFor: 'instance creation' !
on: aWindow

	^self new
		window: aWindow;
		yourself
! !

