			beginPolygon;
			polygonColor: color;
			moveToPin: 40;
			moveToPin: i + 1;
			moveToPin: i + 2;
			endPolygon.
		color := color copy hue: color hue + (360.0 / 80.0) ]
! !

! PinBoard methodsFor: 'user art' !
rgbMandala

	self clearStrings.
	self circle.

	self color: 'red'.
	1 to: 40 do: [:pin |
		self moveToPin: pin.
		self lineToPin: pin + 9].

	self color: 'blue'.
	1 to: 40 do: [:pin |
		self moveToPin: pin.
		self lineToPin: pin + 19].

	self color: 'green'.
	1 to: 40 do: [:pin |
		self moveToPin: pin.
		self lineToPin: pin + 15]  ! !

