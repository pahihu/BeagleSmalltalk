! PinBoard methodsFor: 'user art' !
polygonFan

	| color |

	self clearStrings.
	self circle: 80.

	color := Color red: 255 green: 0 blue: 255 alpha: 255.

	2 to: 79 do: [:i |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 1;
			moveToPin: i + 1;
			moveToPin: i + 2;
			endPolygon.
		color := color hue: color hue + (360.0 / 80.0)]

! !

