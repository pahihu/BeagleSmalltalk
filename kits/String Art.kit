KitManager default currentKitNamed: 'String Art' !

KitManager default currentKit ensureLoaded: #('Canvas Window') !

Object subclassNamed: #Pin
	instVarNames: 'number radius location label fillColor lineColor labelColor labelFont labelOffset visible'
	classInstVarNames: ''
	environment: Object systemDictionary
	kitName: 'String Art' !

Object subclassNamed: #PinBoard
	instVarNames: 'pins strings polygons currentPin currentStringColor currentPolygon'
	classInstVarNames: ''
	environment: Object systemDictionary
	kitName: 'String Art' !

Object subclassNamed: #PinPolygon
	instVarNames: 'vertices color'
	classInstVarNames: ''
	environment: Object systemDictionary
	kitName: 'String Art' !

Object subclassNamed: #PinString
	instVarNames: 'startPin endPin color'
	classInstVarNames: ''
	environment: Object systemDictionary
	kitName: 'String Art' !

CanvasWindow subclassNamed: #StringArtWindow
	instVarNames: 'pins currentPin board currentResult'
	classInstVarNames: ''
	environment: Object systemDictionary
	kitName: 'String Art' !

! Pin methodsFor: 'accessing' !
fillColor

	^fillColor ! !

! Pin methodsFor: 'accessing' !
fillColor: aString

	fillColor := aString ! !

! Pin methodsFor: 'accessing' !
label

	^label ! !

! Pin methodsFor: 'accessing' !
label: aString

	label := aString ! !

! Pin methodsFor: 'accessing' !
labelColor

	^labelColor! !

! Pin methodsFor: 'accessing' !
labelColor: aString

	labelColor := aString ! !

! Pin methodsFor: 'accessing' !
labelFont

	^labelFont ! !

! Pin methodsFor: 'accessing' !
labelFont: aString

	labelFont := aString ! !

! Pin methodsFor: 'accessing' !
labelOffset

	^labelOffset ! !

! Pin methodsFor: 'accessing' !
labelOffset: aPoint

	labelOffset := aPoint ! !

! Pin methodsFor: 'accessing' !
lineColor

	^lineColor ! !

! Pin methodsFor: 'accessing' !
lineColor: aString

	lineColor := aString ! !

! Pin methodsFor: 'accessing' !
location

	^location! !

! Pin methodsFor: 'accessing' !
location: aPoint

	location := aPoint! !

! Pin methodsFor: 'accessing' !
number

	^number ! !

! Pin methodsFor: 'accessing' !
number: aNumber

	number := aNumber ! !

! Pin methodsFor: 'accessing' !
radius

	^radius ! !

! Pin methodsFor: 'accessing' !
radius: aNumber

	radius := aNumber ! !

! Pin methodsFor: 'accessing' !
visible

	^visible ! !

! Pin methodsFor: 'accessing' !
visible: aBoolean

	visible := aBoolean ! !

! Pin methodsFor: 'displaying' !
displayLabelOn: aPen

	self label isNil ifTrue: [^self].

	aPen
		fillStyle: self labelColor;
		font: self labelFont;
		drawText: self label at: self location + self labelOffset 
! !

! Pin methodsFor: 'displaying' !
displayOn: aPen

	self
		displayPinOn: aPen;
		displayLabelOn: aPen! !

! Pin methodsFor: 'displaying' !
displayPinOn: aPen

	self visible ifFalse: [^self].

	aPen
		fillStyle: self fillColor;
		drawFilledCircleRadius: self radius at: self location;
		strokeStyle: self lineColor;
		drawCircleRadius: self radius at: self location.
 ! !

! Pin methodsFor: 'initializing' !
initialize

	self
		lineColor: 'black';
		fillColor: 'black';
		labelColor: 'black';
		radius: 1;
		labelFont: '10px Arial';
		labelOffset: 0 @ 0;
		label: nil;
		visible: true ! !

! Pin methodsFor: 'printing' !
printOn: aStream

	aStream nextPutAll: 'pin-', self number printString! !

! Pin class methodsFor: 'instance creation' !
new

	^super new initialize; yourself! !

! PinBoard methodsFor: 'accessing' !
color: aString

	self currentStringColor: aString ! !

! PinBoard methodsFor: 'accessing' !
currentPin

	^currentPin! !

! PinBoard methodsFor: 'accessing' !
currentPin: aPin

	currentPin := aPin! !

! PinBoard methodsFor: 'accessing' !
currentPolygon

	^currentPolygon ! !

! PinBoard methodsFor: 'accessing' !
currentPolygon: aCollection

	currentPolygon := aCollection ! !

! PinBoard methodsFor: 'accessing' !
currentStringColor

	^currentStringColor! !

! PinBoard methodsFor: 'accessing' !
currentStringColor: aString

	currentStringColor := aString! !

! PinBoard methodsFor: 'accessing' !
pins

	^pins! !

! PinBoard methodsFor: 'accessing' !
pins: aCollection

	pins := aCollection! !

! PinBoard methodsFor: 'accessing' !
polygonColor: aColor

	self currentPolygon isNil ifTrue: [^self].
	self currentPolygon color: aColor

! !

! PinBoard methodsFor: 'accessing' !
polygons

	^polygons! !

! PinBoard methodsFor: 'accessing' !
polygons: aCollection

	polygons := aCollection! !

! PinBoard methodsFor: 'accessing' !
strings

	^strings! !

! PinBoard methodsFor: 'accessing' !
strings: aCollection

	strings := aCollection! !

! PinBoard methodsFor: 'adding and removing' !
addPinAt: aPoint

	| pin |

	self pins add: (pin := Pin new
		location: aPoint;
		number: self pins size + 1;
		yourself).

	^pin ! !

! PinBoard methodsFor: 'adding and removing' !
clear

	self clearPins! !

! PinBoard methodsFor: 'adding and removing' !
clearPins

	self
		pins: OrderedCollection new;
		clearStrings;
		currentPin: nil
! !

! PinBoard methodsFor: 'adding and removing' !
clearPolygons

	self polygons: OrderedCollection new! !

! PinBoard methodsFor: 'adding and removing' !
clearStrings

	self
		strings: OrderedCollection new;
		currentStringColor: 'black';
		clearPolygons! !

! PinBoard methodsFor: 'adding and removing' !
pinAt: aNumber

	^self pins at: ((aNumber - 1) \\ pins size) + 1! !

! PinBoard methodsFor: 'drawing' !
beginPolygon

	self currentPolygon: PinPolygon new ! !

! PinBoard methodsFor: 'drawing' !
black

	self color: 'black'! !

! PinBoard methodsFor: 'drawing' !
blue

	self color: 'blue'! !

! PinBoard methodsFor: 'drawing' !
displayOn: aPen

	self pins do: [:pin | pin displayOn: aPen].
	self strings do: [:string | string displayOn: aPen].
	self polygons do: [:polygon | polygon displayOn: aPen].

 ! !

! PinBoard methodsFor: 'drawing' !
endPolygon

	self currentPolygon isNil ifTrue: [^self].
	self polygons add: self currentPolygon.
	self currentPolygon: nil! !

! PinBoard methodsFor: 'drawing' !
gray

	self color: 'gray'! !

! PinBoard methodsFor: 'drawing' !
green

	self color: 'green'! !

! PinBoard methodsFor: 'drawing' !
lineToPin: pinNumber

	| nextPin |
	self currentPin isNil ifTrue: [^self].

	nextPin := self pinAt: pinNumber.
	self strings add: (PinString new
		startPin: self currentPin;
		endPin: nextPin;
		color: self currentStringColor;
		yourself).

	self currentPin: nextPin.
	self currentPolygon notNil ifTrue: [currentPolygon moveToPin: self currentPin].

! !

! PinBoard methodsFor: 'drawing' !
moveToPin: pinNumber

	self currentPin: (self pinAt: pinNumber).
	self currentPolygon notNil ifTrue: [currentPolygon moveToPin: self currentPin] ! !

! PinBoard methodsFor: 'drawing' !
red

	self color: 'red'! !

! PinBoard methodsFor: 'drawing' !
yellow

	self color: 'yellow'! !

! PinBoard methodsFor: 'initializing' !
initialize

	self clearPins ! !

! PinBoard methodsFor: 'printing' !
printOn: aStream

	aStream
		nextPutAll: 'Board'; cr;
		nextPutAll: '    currentPin: ', self currentPin printString; cr;
		nextPutAll: '    currentStringColor: ', self currentStringColor printString; cr;
		nextPutAll: '    pins: ', self pins asArray printString; cr;
		nextPutAll: '    strings: ', self strings asArray printString; cr;
		nextPutAll: '    currentPolygon: ', self currentPolygon printString; cr;
		nextPutAll: '    polygons: ', self polygons asArray printString; cr;
		cr

! !

! PinBoard methodsFor: 'setting up pins' !
circle

	self circle: 40
  ! !

! PinBoard methodsFor: 'setting up pins' !
circle: numberOfPins

	self circleRadius: 80 pins: numberOfPins
  ! !

! PinBoard methodsFor: 'setting up pins' !
circleRadius: radius pins: numberOfPins

	| angle |

	self clearPins.
	angle := 0.0.

	1 to: numberOfPins do: [:pinNumber |
		| point |
		point := ((angle degreesToRadians) cos @ (angle degreesToRadians) sin) * radius.
		self addPinAt: point.
		angle := angle + (360.0 / numberOfPins)].
   ! !

! PinBoard methodsFor: 'setting up pins' !
circleWithCenter

	self circleWithCenter: 40
   ! !

! PinBoard methodsFor: 'setting up pins' !
circleWithCenter: numberOfPins

	self circleRadius: 80 pins: numberOfPins.
	self addPinAt: 0.0 @ 0.0
   ! !

! PinBoard methodsFor: 'setting up pins' !
hexagon

	^self hexagonWithSides: 10! !

! PinBoard methodsFor: 'setting up pins' !
hexagonWithSides: aNumber

	^self regularPolygon: 6 radius: 80 startAngle: 0 pinsBetweenVertices: aNumber - 1! !

! PinBoard methodsFor: 'setting up pins' !
hideLabels

	self pins do: [:pin |
		pin label: nil] ! !

! PinBoard methodsFor: 'setting up pins' !
hidePins

	self pins do: [:pin | pin visible: false] ! !

! PinBoard methodsFor: 'setting up pins' !
pentagon

	^self pentagonWithSides: 10! !

! PinBoard methodsFor: 'setting up pins' !
pentagonWithSides: aNumber

	^self regularPolygon: 5 radius: 80 startAngle: 90 / 5 pinsBetweenVertices: aNumber - 1! !

! PinBoard methodsFor: 'setting up pins' !
regularPolygon: numberOfCorners radius: radius startAngle: startAngle pinsBetweenVertices: pinsBetweenVertices

	| angle lastPoint |

	self clearPins.
	angle := startAngle.
	lastPoint := nil.

	0 to: numberOfCorners - 1 do: [:pinNumber |
		| point |
		point := ((angle degreesToRadians) cos @ (angle degreesToRadians) sin) * radius.
		lastPoint isNil ifFalse: [
			| deltaPoint |
			deltaPoint := (point - lastPoint) / (pinsBetweenVertices + 1) asFloat.
			1 to: pinsBetweenVertices do: [:each |
				self addPinAt: lastPoint + (deltaPoint * each)]
			].
		lastPoint := point.
		self addPinAt: point.
		angle := angle + (360.0 / numberOfCorners asFloat)].

	lastPoint isNil ifFalse: [
		| deltaPoint2 |
		deltaPoint2 := (pins first location - lastPoint) / (pinsBetweenVertices + 1) asFloat.
		1 to: pinsBetweenVertices do: [:each |
			self addPinAt: lastPoint + (deltaPoint2 * each)]
		]! !

! PinBoard methodsFor: 'setting up pins' !
showLabels

	self pins do: [:pin |
		pin
			label: pin number printString;
			labelOffset: pin location / 10] ! !

! PinBoard methodsFor: 'setting up pins' !
showPins

	self pins do: [:pin | pin visible: true] ! !

! PinBoard methodsFor: 'setting up pins' !
square

	^self squareWithSides: 10! !

! PinBoard methodsFor: 'setting up pins' !
squareWithSides: aNumber

	^self regularPolygon: 4 radius: 80 startAngle: 45 pinsBetweenVertices: aNumber - 1! !

! PinBoard methodsFor: 'setting up pins' !
triangle

	^self triangleWithSides: 10! !

! PinBoard methodsFor: 'setting up pins' !
triangleWithSides: aNumber

	^self regularPolygon: 3 radius: 80 startAngle: 0 pinsBetweenVertices: aNumber - 1! !

! PinBoard methodsFor: 'user art' !
circularRainbow

	| color |

	self clearStrings.
	self circleWithCenter: 80.

	color := Color red: 255 green: 0 blue: 0 alpha: 255.

	1 to: 79 do: [:i |
		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 81;
			moveToPin: i ;
			moveToPin: i + 1;
			endPolygon.
		color := color hue: color hue + (360.0 / 80.0)].

		self
			beginPolygon;
			polygonColor: color;
			moveToPin: 81;
			moveToPin: 80;
			moveToPin: 1;
			endPolygon.
! !

! PinBoard methodsFor: 'user art' !
hexagonArches

	| color |

	self hexagonWithSides: 20.

	color := Color red: 255 green: 0 blue: 0.

	1 to: 20 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	21 to: 40 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	41 to: 60 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	61 to: 80 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	81 to: 100 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)].

	101 to: 120 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 20.
		color := color hue: color hue + (360.0 / 120.0)]
! !

