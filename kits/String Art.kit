		color := color hue: color hue + (360.0 / 120.0)].

	41 to: 60 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 40.
		color := color hue: color hue + (360.0 / 120.0)].

	61 to: 80 do: [:each |
		self color: color.
		self moveToPin: each;
			lineToPin: each + 40.
		color := color hue: color hue + (360.0 / 120.0)].

	81 to: 100 do: [:each |
