			moveToPin: 21;
			endPolygon.
! !

! PinBoard methodsFor: 'user art' !
twoPointFan

	self clearStrings.
	self circle: 100.

	self color: 'green'.
	self moveToPin: 1.

	1 to: self pins size do: [:pin |
		self moveToPin: 1.
		self lineToPin: pin].

	self color: 'blue'.
	1 to: self pins size do: [:pin |
		self moveToPin: self pins size // 2 + 1.
		self lineToPin: self pins size // 2 + 1 + pin] ! !

! PinBoard class methodsFor: 'instance creation' !
new

	^super new initialize; yourself! !

! PinPolygon methodsFor: 'accessing' !
color

	^color ! !

! PinPolygon methodsFor: 'accessing' !
color: aColor

	color := aColor ! !

! PinPolygon methodsFor: 'accessing' !
moveToPin: aPinNumber

	vertices add: aPinNumber! !

! PinPolygon methodsFor: 'accessing' !
vertices

	^vertices ! !

! PinPolygon methodsFor: 'accessing' !
vertices: aCollection

	vertices := aCollection ! !

! PinPolygon methodsFor: 'displaying' !
displayOn: aPen

	| firstTime |

	vertices isEmpty ifTrue: [^self].

	firstTime := true.

	aPen
		fillStyle: self color asString;
		fillPath: [:pen |
			self vertices do: [:vertex | 
				firstTime
					ifTrue: [pen moveTo: vertex location]
					ifFalse: [pen lineTo: vertex location].
				firstTime := false]].

	aPen lineTo: vertices first location


! !

! PinPolygon methodsFor: 'initializing' !
initialize

	self vertices: OrderedCollection new.
 	self color: (Color red: 255 green: 0 blue: 255 alpha: 128)! !

! PinPolygon class methodsFor: 'instance creation' !
new

	^super new initialize; yourself! !

! PinString methodsFor: 'accessing' !
color

	^color! !

! PinString methodsFor: 'accessing' !
color: aString

	color := aString! !

! PinString methodsFor: 'accessing' !
endPin

	^endPin! !

! PinString methodsFor: 'accessing' !
endPin: aPin

	endPin := aPin! !

! PinString methodsFor: 'accessing' !
startPin

	^startPin! !

! PinString methodsFor: 'accessing' !
startPin: aPin

	startPin := aPin! !

! PinString methodsFor: 'displaying' !
displayOn: aPen

	aPen
		strokeStyle: self color asString;
		lineFrom: self startPin location to: self endPin location! !

! PinString methodsFor: 'printing' !
printOn: aStream

	aStream
		nextPutAll: (self color isString ifTrue: [self color] ifFalse: [self color printString]);
		nextPutAll: '-';
		print: startPin;
		nextPutAll: '-';
		print: endPin! !

! StringArtWindow methodsFor: 'accessing' !
board

	^board ! !

! StringArtWindow methodsFor: 'accessing' !
board: anObject

	board := anObject ! !

! StringArtWindow methodsFor: 'accessing' !
currentResult

	^currentResult! !

! StringArtWindow methodsFor: 'accessing' !
currentResult: anObject

	currentResult := anObject! !

! StringArtWindow methodsFor: 'accessing' !
pinBoard

	^board ! !

! StringArtWindow methodsFor: 'accessing' !
pinBoard: aPinBoard

	board := aPinBoard ! !

! StringArtWindow methodsFor: 'building' !
buildOn: aWindowBuilder

	aWindowBuilder
		verticalLayout: '35px 1fr 200px' id: 'StringArtDiv';
			horizontalLayout: '5sp 100px 100px 100px 100px 100px 100px 100px 1fr' id: 'toolBar';
				pushButton: 'clearStrings';
					label: 'Clear Strings';
					action: [self clearScreen. self board clearStrings. self update];
				end;
				pushButton: 'clearPins';
					label: 'Clear Pins';
					action: [self clearScreen. self board clearPins. self update];
				end;
				pushButton: 'draw';
					label: 'Draw';
					action: [self doAndDrawBoard];
				end;
				pushButton: 'hideLabels';
					label: 'Hide Labels';
					action: [self clearScreen. self board hideLabels. self update];
				end;
				pushButton: 'showLabels';
					label: 'Show Labels';
					action: [self clearScreen. self board showLabels. self update];
				end;
				pushButton: 'inspect';
					label: 'Inspect';
					action: [self board inspect. self update];
				end;
				pushButton: 'browse';
					label: 'Browse';
					action: [CodeBrowser openOnClass: self board class];
				end;
				divId: 'toolbarWhiteSpace';
				end;
			end;
		horizontalLayout: '1fr 1fr' id: 'canvasLayout';
			richTextWidget: #workspace;
				menu: self codeMenu;
				subject: self;
			end;
			canvasWidget: #canvas;
			end;
		end;
		richTextWidget: #boardView;
			subject: self board;
		end;
	end  ! !

! StringArtWindow methodsFor: 'drawing' !
backgroundColor: aString

	self canvasWidget backgroundColorString: aString; setStyle! !

! StringArtWindow methodsFor: 'drawing' !
drawBoard

	self board displayOn: self pen  ! !

! StringArtWindow methodsFor: 'initializing' !
initialize

	super initialize.
	self board: PinBoard new.
	self currentResult: self board! !

! StringArtWindow methodsFor: 'menus' !
doAndDrawBoard

	self clearScreen.
	self disableWhile: [currentResult := (self bindingAt: #workspace) evaluateAll].
	self update    ! !

! StringArtWindow methodsFor: 'menus' !
drawWith: aDictionary

	self clearScreen.
	self disableWhile: [currentResult := (self bindingAt: #workspace) evaluateAll].
	self update    ! !

! StringArtWindow methodsFor: 'opening' !
defaultTitle

	^'String Art'! !

! StringArtWindow methodsFor: 'opening' !
defaultWindowExtent

	^1000 @ 700! !

! StringArtWindow methodsFor: 'opening' !
postOpen

	super postOpen.
	self update! !

! StringArtWindow methodsFor: 'setting up pins' !
circleRadius: radius pins: numberOfPins

	self board circleRadius: radius pins: numberOfPins  ! !

! StringArtWindow methodsFor: 'setting up pins' !
regularPolygon: numberOfPins radius: radius startAngle: startAngle pinsBetweenVertices: pinsBetweenVertices

	self board regularPolygon: numberOfPins radius: radius startAngle: startAngle pinsBetweenVertices: pinsBetweenVertices  ! !

! StringArtWindow methodsFor: 'updating' !
drawBoardView

	| stream |
	stream := WriteStream on: (String new: 1000).
	self currentResult printOn: stream.

	(self bindingAt: #boardView) text: stream contents
! !

! StringArtWindow methodsFor: 'updating' !
update

	self drawBoard.
	self drawBoardView.
	super update ! !

! StringArtWindow methodsFor: 'widgets' !
clearPinsWidget

	^self bindingAt: #clearPins ifAbsentPut: [
		PushButtonComponent new
			bindTo: self as: 'clearPins';
			label: 'Clear Pins';
			actionBlock: [self clearScreen. self pinBoard clearPins. self update];
			yourself] ! !

! StringArtWindow methodsFor: 'widgets' !
clearStringsWidget

	^self bindingAt: #clearStrings ifAbsentPut: [
		PushButtonComponent new
			bindTo: self as: 'clearStrings';
			label: 'Clear Strings';
			actionBlock: [self clearScreen. self pinBoard clearStrings. self update];
			yourself] ! !

! StringArtWindow methodsFor: 'widgets' !
drawWidget

	^self bindingAt: #draw ifAbsentPut: [
		PushButtonComponent new
			bindTo: self as: 'draw';
			label: 'Draw';
			actionBlock: [:args | self drawWith: args];
			yourself] ! !

! StringArtWindow methodsFor: 'widgets' !
hideLabelsWidget

	^self bindingAt: #hideLabels ifAbsentPut: [
		PushButtonComponent new
			bindTo: self as: 'hideLabels ';
			label: 'Hide Labels';
			actionBlock: [self clearScreen. self pinBoard hideLabels. self update];
			yourself] ! !

! StringArtWindow methodsFor: 'widgets' !
showLabelsWidget

	^self bindingAt: #showLabels ifAbsentPut: [
		PushButtonComponent new
			bindTo: self as: 'showLabels ';
			label: 'Show Labels';
			actionBlock: [self clearScreen. self pinBoard showLabels. self update];
			yourself] ! !

