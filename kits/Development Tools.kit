		name: 'Rename Workspace...';
		action: [:args | self renameWorkspaceWith: args];
		yourself! !

! Workspace methodsFor: 'code menu' !
renameWorkspaceWith: aDictionary

	self request: 'New title?' initialAnswer: 'Workspace' answerBlock: [:string |
		string notNil ifTrue: [
			self title: string; updateTitle]]! !

! Workspace methodsFor: 'code menu' !
save: aString to: filenameString

	| file |

	file := filenameString asFilename writeStream.
	file nextPutAll: aString.
	file close
! !

