		id: #doIt;
		name: 'Do It';
		addRequestedValue: 'richTextSelectionStart';
		addRequestedValue: 'richTextSelectionEnd';
		action: [:args | self doItWith: args];
		yourself ! !

! Debugger methodsFor: 'code menu' !
doItWith: aDictionary

	self disableWhile: [self codeWidget
		subject: self getSelf;
		evaluateFrom: (aDictionary at: 'richTextSelectionStart') + 1 to: (aDictionary at: 'richTextSelectionEnd') onError: [^self]]  ! !

! Debugger methodsFor: 'code menu' !
inspectItMenuItem

