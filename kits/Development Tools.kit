methods
	^methods! !

! CodeBrowser methodsFor: 'accessing' !
methods: aCollection
	methods := aCollection! !

! CodeBrowser methodsFor: 'accessing' !
protocols
	^protocols! !

! CodeBrowser methodsFor: 'accessing' !
protocols: aCollection
	protocols := aCollection! !

! CodeBrowser methodsFor: 'accessing' !
selectedClass
	^selectedClass! !

! CodeBrowser methodsFor: 'accessing' !
selectedClass: aClass
	selectedClass := aClass! !

! CodeBrowser methodsFor: 'accessing' !
selectedKit
	^selectedKit! !

! CodeBrowser methodsFor: 'accessing' !
selectedKit: aKit
	selectedKit := aKit! !

! CodeBrowser methodsFor: 'accessing' !
selectedMethod
