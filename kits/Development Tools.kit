		id: #timeit;
		name: 'Time It';
		addRequestedValue: 'pageX';
		addRequestedValue: 'pageY';
		addRequestedValue: 'richTextSelectionStart';
		addRequestedValue: 'richTextSelectionEnd';
		addRequestedValue: 'innerHTML';
		action: [:args | self timeItWith: args];
		yourself ! !

