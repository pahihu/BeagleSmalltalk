simulator

	^simulator! !

! Debugger methodsFor: 'accessing' !
simulator: aCodeSimulator

	simulator := aCodeSimulator! !

! Debugger methodsFor: 'actions' !
inspectSimulator

	self simulator inspect
! !

! Debugger methodsFor: 'actions' !
into

	self simulator into.
	self peekBytecode! !

! Debugger methodsFor: 'actions' !
over

	self simulator over.
	self peekBytecode! !

! Debugger methodsFor: 'actions' !
peekBytecode

	self message: (self simulator currentContext method decompileSingleBytecodeStartingAt: self simulator currentContext pcOffset).
	self currentFrame: self simulator currentContext.
	self update

! !

! Debugger methodsFor: 'actions' !
restart

	self simulator
		returnToFrame: self currentFrame;
		restart.
	self
		update;
		peekBytecode! !

! Debugger methodsFor: 'actions' !
restartMethod

	self simulator returnToFrame: self currentFrame rootContext frame.! !

! Debugger methodsFor: 'actions' !
restartMethod: aCompiledMethod

	self simulator returnToFrame: self currentFrame rootContext frame.
	self simulator buildFrameFor: aCompiledMethod.
	self currentFrame: self simulator currentContext! !

! Debugger methodsFor: 'actions' !
return

	
	self request: 'Expression?' initialAnswer: 'self' answerBlock: [:string |
		self simulator currentContext push: (SmalltalkParser evaluate: string for: self getSelf).
		self simulator return.
		self peekBytecode]  at: self origin + (50 @ 50)! !

! Debugger methodsFor: 'actions' !
stepBytecode

	self simulator stepBytecode.
	self peekBytecode! !

! Debugger methodsFor: 'actions' !
through

	self simulator through.
	self peekBytecode! !

! Debugger methodsFor: 'building' !
buildOn: aWindowBuilder

	aWindowBuilder
		verticalLayout: '35px 1fr 1fr 3fr 1fr' id: 'DebuggerDiv';
			horizontalLayout: '5sp 108px 105px 38px 68px 44px 58px 56px 59px 1fr' id: 'toolBar';
				pushButton: 'peekBytecode';
					label: 'Peek Bytecode';
					action: [self peekBytecode];
				end;
				pushButton: 'stepBytecode';
					label: 'Step Bytecode';
					action: [self stepBytecode];
				end;
				pushButton: 'into';
					label: 'Into';
					action: [self into];
				end;
				pushButton: 'through';
					label: 'Through';
					action: [self through];
				end;
				pushButton: 'over';
					label: 'Over';
					action: [self over];
				end;
				pushButton: 'restart';
					label: 'Restart';
					action: [self restart];
				end;
				pushButton: 'return';
					label: 'Return';
					action: [self return];
				end;
				pushButton: 'inspectSimulator';
					label: 'Inspect';
					action: [self inspectSimulator];
				end;
				divId: 'toolbarWhiteSpace';
				end;
			end;
			richTextWidget: 'messageEditor';
			end;
			horizontalLayout: '1fr 1fr 1fr' id: 'walkbackComponents';
				listWidget: #walkbackList ;
					onSelection: #changedWalkbackSelectionEvent:;
				end;
				listWidget: #stackInspectorList;
					onSelection: #changedStackSelectionEvent:;
					menu: self stackInspectMenu;
				end;
				richTextWidget: 'stackTextEditor';
				end;
			end;
			richTextWidget: 'codeEditor';
				menu: self codeMenu;				
			end;
			horizontalLayout: '1fr 1fr 1fr 1fr' id: 'inspectorComponents';
				listWidget: #selfInspectorList;
					onSelection: #changedInspectorSelectionEvent:;
					menu: self selfInspectMenu;
				end;
				richTextWidget: 'selfTextEditor';
				end;
				listWidget: #localsInspectorList;
					onSelection: #changedLocalsSelectionEvent:;
					menu: self localsInspectMenu;
				end;
				richTextWidget: 'localsTextEditor';
				end;
			end;
		end



   ! !

! Debugger methodsFor: 'changing' !
changedInspectorSelection: aNumber

	self selectedField: aNumber.
	self updateSelfTextEditor! !

! Debugger methodsFor: 'changing' !
changedInspectorSelectionEvent: anEvent

	self changedInspectorSelection: anEvent selectionIndex  ! !

! Debugger methodsFor: 'changing' !
