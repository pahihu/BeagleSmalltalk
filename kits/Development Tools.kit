selectedField

	^selectedField ! !

! Inspector methodsFor: 'accessing' !
selectedField: aNumber

	selectedField := aNumber ! !

! Inspector methodsFor: 'actions' !
diveIn

	self selectedObject isNil ifTrue: [^self].

	objectStack add: self object.
	self object: self selectedObject.
	self updateObjectInWorkspace.
	self selectedField: nil.

	self updateFieldList.
	self updateList; updateText; updateTitle! !

! Inspector methodsFor: 'actions' !
doBasicInspect

	self selectedObject basicInspect! !

! Inspector methodsFor: 'actions' !
doInspect

	self selectedObject inspect! !

! Inspector methodsFor: 'actions' !
popOut

	objectStack isEmpty ifTrue: [^self].
	self object: objectStack removeLast.
	self updateObjectInWorkspace.
	self selectedField: nil.

	self updateFieldList.
	self updateList; updateText; updateTitle! !

! Inspector methodsFor: 'building' !
buildOn: aBuilder

	aBuilder
		verticalLayout: '1fr 1fr' id: 'inspectorDiv';
			horizontalLayout: '1fr 1fr' id: 'inspectorCore';
				listWidget: #fieldsList;
					menu: self fieldMenu;
					onSelection: #changedSelectedField:;
					onDoubleClick: #diveInWith:;
				end;
				richTextWidget: #inspectorTextBox;
				end;
			end;
			richTextWidget: #inspectorWorkspace;
				menu: self codeMenu;
			end;
		end
! !

! Inspector methodsFor: 'changing' !
changedSelectedField: anEvent

	self selectedField: anEvent selectionIndex.
	self updateText
 ! !

