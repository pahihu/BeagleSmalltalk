kitMenu

	^PopupMenuUI new
		widgetId: (self idFor: 'kitListDiv');
		addMenuItem: self findClassMenuItem;
		addMenuItem: self newKitMenuItem;
		addMenuItem: self removeKitMenuItem;
		addMenuItem: self fileoutKitMenuItem;
		addMenuItem: self unloadKitMenuItem;
		yourself! !

