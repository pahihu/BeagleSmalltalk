	^PopupMenuUI new
		widgetId: self codeEditorId;
		addMenuItem: self saveMenuItem;
		addMenuItem: self doItMenuItem;
		addMenuItem: self printItMenuItem;
		addMenuItem: self inspectItMenuItem;
		yourself ! !

